<html lang="zh">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>高频词语统计</title>
  <link rel="stylesheet" href="/theme.css">
  <style>
    body { background: var(--paper); }

    /* ── 页面头部 ── */
    .page-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 24px;
      padding-bottom: 16px;
      border-bottom: 0.5px solid var(--border-light);
      animation: fadeDown 0.5s var(--ease-out) both;
    }
    .page-header h2 {
      font-size: 22px;
      font-weight: 800;
      color: #0a1628;
      font-family: var(--font-display);
      margin: 0;
      animation: titleRise 0.6s var(--ease-spring) 0.08s both;
    }
    @keyframes titleRise {
      from { opacity: 0; transform: translateY(16px) scale(0.96); }
      to   { opacity: 1; transform: translateY(0) scale(1); }
    }
    @keyframes fadeDown {
      from { opacity: 0; transform: translateY(-10px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── Sub nav ── */
    .sub-nav {
      display: flex;
      gap: 8px;
      margin-bottom: 24px;
      animation: fadeUp 0.4s var(--ease-out) 0.12s both;
    }
    .sub-nav a {
      padding: 8px 20px;
      border-radius: 980px;
      font-size: 14px;
      font-weight: 600;
      text-decoration: none;
      color: var(--text-sec);
      background: var(--card);
      border: 0.5px solid var(--border-light);
      transition: all 0.25s var(--ease-out);
    }
    .sub-nav a:hover { border-color: var(--g-300); color: #0a1628; }
    .sub-nav a.active {
      background: var(--g-600);
      color: #fff;
      border-color: var(--g-600);
    }

    /* ── 统计栏 ── */
    .stats-bar {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 24px;
    }
    .stats-bar-item {
      background: var(--card);
      border: 0.5px solid var(--border-light);
      border-radius: 10px;
      padding: 12px 20px;
      font-size: 13px;
      color: var(--text-sec);
      opacity: 0;
      transform: translateY(10px);
      transition: opacity 0.25s var(--ease-out), transform 0.25s var(--ease-out);
    }
    .stats-bar-item.visible {
      opacity: 1;
      transform: translateY(0);
    }
    .stats-bar-item b {
      color: #0a1628;
      font-weight: 700;
      font-size: 16px;
    }

    /* ── 词语网格 ── */
    .word-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 10px;
    }
    .word-card {
      background: var(--card);
      border: 0.5px solid var(--border-light);
      border-radius: 10px;
      padding: 12px 14px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      cursor: pointer;
      transition: border-color 0.25s, box-shadow 0.25s;
      opacity: 0;
      transform: translateY(12px);
    }
    .word-card.visible {
      opacity: 1;
      transform: translateY(0);
      transition: opacity 0.35s var(--ease-out), transform 0.35s var(--ease-out),
                  border-color 0.25s, box-shadow 0.25s;
    }
    .word-card.visible:hover {
      border-color: var(--brand-400, #4d94ff);
      box-shadow: 0 6px 16px rgba(0,102,204,0.10);
      transform: translateY(-3px);
      transition: transform 0.2s var(--ease-out), border-color 0.2s, box-shadow 0.2s;
    }
    .word-card.visible:active {
      transform: translateY(-1px);
    }
    .word-card .word-text {
      font-size: 15px;
      font-weight: 700;
      color: #0a1628;
      font-family: var(--font-display);
    }
    .word-card .word-count {
      font-size: 12px;
      font-weight: 600;
      padding: 3px 10px;
      border-radius: 12px;
      white-space: nowrap;
    }
    .word-count-high { background: #fef0ee; color: #c0392b; }
    .word-count-mid { background: #fef9ee; color: #b8860b; }
    .word-count-low { background: #dce8f5; color: #1a5a3a; }

    /* ── 题目详情面板 ── */
    .question-panel {
      position: fixed;
      top: 0; left: 0; right: 0; bottom: 0;
      background: rgba(0,0,0,0.4);
      z-index: 1000;
      overflow-y: auto;
      padding: 40px 20px;
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.25s var(--ease-out), visibility 0.25s;
    }
    .question-panel.show {
      opacity: 1;
      visibility: visible;
    }
    .question-panel-inner {
      max-width: 720px;
      margin: 0 auto;
      background: var(--card);
      border-radius: 16px;
      padding: 24px;
      box-shadow: 0 12px 40px rgba(0,0,0,0.15);
      max-height: 80vh;
      overflow-y: auto;
      transform: scale(0.92) translateY(20px);
      opacity: 0;
      transition: transform 0.4s var(--ease-spring), opacity 0.3s var(--ease-out);
    }
    .question-panel.show .question-panel-inner {
      transform: scale(1) translateY(0);
      opacity: 1;
    }
    .question-panel-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 16px;
      padding-bottom: 12px;
      border-bottom: 0.5px solid var(--border-light);
      position: sticky;
      top: 0;
      background: var(--card);
      z-index: 1;
    }
    .question-panel-header h3 {
      margin: 0;
      font-size: 16px;
      font-weight: 700;
      color: #0a1628;
    }
    .question-panel-header .close-btn {
      font-size: 20px;
      cursor: pointer;
      color: var(--text-ter);
      background: none;
      border: none;
      padding: 4px 8px;
      border-radius: 8px;
      transition: all 0.2s;
    }
    .question-panel-header .close-btn:hover { background: var(--g-50); color: var(--text-900); }

    .question-item {
      padding: 16px 0;
      border-bottom: 0.5px solid #eaf1fb;
      animation: fadeUp 0.35s var(--ease-out) both;
    }
    .question-item:last-child { border-bottom: none; }
    .question-item .q-source {
      font-size: 12px;
      color: var(--text-ter);
      margin-bottom: 8px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .question-item .q-source .q-num {
      background: var(--g-100);
      color: var(--g-700);
      font-weight: 700;
      padding: 2px 8px;
      border-radius: 6px;
      font-size: 11px;
    }
    .question-item .q-content {
      font-size: 14px;
      line-height: 1.8;
      color: var(--text);
      margin-bottom: 10px;
    }
    .question-item .q-options {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 6px 16px;
      font-size: 13px;
      color: var(--text-sec);
      margin-bottom: 10px;
    }
    .question-item .q-options div {
      padding: 6px 10px;
      background: #f8faff;
      border-radius: 6px;
      border: 0.5px solid #edf2fa;
    }
    .question-item .q-options div.correct-opt {
      background: #f0f7e8;
      border-color: var(--brand-600);
      color: #2d6a1e;
      font-weight: 600;
    }
    .question-item .q-solution {
      font-size: 13px;
      line-height: 1.7;
      color: var(--text-sec);
      background: #f5f9ff;
      padding: 12px 14px;
      border-radius: 8px;
      border-left: 3px solid #0066cc;
    }
    .question-item .q-solution-title {
      font-size: 12px;
      font-weight: 700;
      color: var(--g-700);
      margin-bottom: 6px;
    }
    .question-loading {
      text-align: center;
      padding: 20px;
      color: var(--text-ter);
    }

    .empty-state {
      text-align: center;
      padding: 60px 20px;
      color: var(--text-ter);
      animation: fadeUp 0.5s var(--ease-out);
    }
    .empty-state .icon { font-size: 48px; margin-bottom: 12px; opacity: 0.3; }
    .empty-state p { font-size: 14px; }

    .loading {
      text-align: center;
      padding: 60px 20px;
      color: var(--text-sec);
    }
    .loading .spinner {
      width: 32px; height: 32px;
      border: 3px solid var(--border-light);
      border-top-color: var(--brand-500);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      margin: 0 auto 12px;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(12px); }
      to   { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>
<body>
<div class="navbar">
  <a href="/history-category-complex" class="logo"><img src="/logo.svg" alt="">错题助手</a>
  <a href="/history-category-complex">练习记录</a>
  <a href="/history">列表视图</a>
  <a href="/wrong-questions">错题本</a>
  <div class="nav-dropdown open">
    <span class="dropdown-toggle">词语统计 &#x25BE;</span>
    <div class="dropdown-menu">
      <a href="/idioms">四字成语</a>
      <a href="/word-stats" class="active">高频词语</a>
    </div>
  </div>
  <a href="/quiz">本地题库</a>
  <a href="/shenlun-format">公文格式</a>
  <% if (typeof userPhone !== 'undefined' && userPhone) { %><span class="nav-user"><span class="user-phone"><%= userPhone %></span><% if (typeof isAdmin !== 'undefined' && isAdmin) { %><span class="admin-badge">管理员<span class="admin-tooltip"><span class="tip-title">👑 管理员权限</span><span class="tip-item">卸载题库</span><span class="tip-item">恢复题库</span><span class="tip-item">查看回收站</span></span></span><% } %></span><% } else { %><span style="margin-left:auto;"></span><% } %>
  <a href="/setup">切换账号</a>
</div>

<div class="page-wrap">
  <div class="page-header">
    <h2>高频词语统计</h2>
  </div>

  <div id="content">
    <div class="loading">
      <div class="spinner"></div>
      <p>正在加载词语数据...</p>
    </div>
  </div>
</div>

<!-- 题目详情弹窗 -->
<div class="question-panel" id="questionPanel">
  <div class="question-panel-inner">
    <div class="question-panel-header">
      <h3 id="panelTitle">题目列表</h3>
      <button class="close-btn" onclick="closePanel()">&#x2715;</button>
    </div>
    <div id="panelContent">
      <div class="question-loading">加载中...</div>
    </div>
  </div>
</div>

<script>
  // ── 动画引擎 ──
  (function(){
    function reveal(selector, baseDelay, stagger) {
      var els = document.querySelectorAll(selector);
      els.forEach(function(el, i){
        setTimeout(function(){ el.classList.add('visible'); }, (baseDelay || 50) + (stagger || 40) * i);
      });
    }
    window._revealCards = function(selector) {
    var els = document.querySelectorAll(selector);
    if(!els.length) return;
    var batchSize = Math.max(20, Math.ceil(els.length / 3));
    for(var b = 0; b < els.length; b += batchSize) {
      (function(batch, delay){
        setTimeout(function(){
          for(var i = batch; i < Math.min(batch + batchSize, els.length); i++){
            els[i].classList.add('visible');
          }
        }, delay);
      })(b, 80 + (b / batchSize) * 100);
    }
  };
  window._revealStats = function(selector) {
    var els = document.querySelectorAll(selector);
    setTimeout(function(){
      els.forEach(function(el){ el.classList.add('visible'); });
    }, 100);
  };
  })();

  var allWords = [];

  fetch('/api/word-frequency')
    .then(function(r) { return r.ok ? r.json() : null; })
    .then(function(data) {
      if (!data || !data.words || data.words.length === 0) {
        document.getElementById('content').innerHTML =
          '<div class="empty-state"><div class="icon">&#x1F4DD;</div><p>暂无高频词语数据<br>错题本中逻辑填空题的选项词语出现次数均未超过3次</p></div>';
        return;
      }

      allWords = data.words;

      var html = '<div class="stats-bar">';
      html += '<div class="stats-bar-item">词语总数：<b>' + allWords.length + '</b></div>';
      html += '<div class="stats-bar-item">筛选条件：<b>出现 &gt; 3 次</b></div>';
      if (data.cachedAt) {
        html += '<div class="stats-bar-item">更新时间：<b>' + new Date(data.cachedAt).toLocaleString('zh-CN') + '</b></div>';
      }
      html += '</div>';

      html += '<div class="word-grid">';
      allWords.forEach(function(item) {
        var countClass = item.count >= 10 ? 'word-count-high' : item.count >= 6 ? 'word-count-mid' : 'word-count-low';
        html += '<div class="word-card" onclick="showWordQuestions(\'' + item.word.replace(/'/g, "\\'") + '\')">';
        html += '<span class="word-text">' + item.word + '</span>';
        html += '<span class="word-count ' + countClass + '">' + item.count + '次</span>';
        html += '</div>';
      });
      html += '</div>';

      document.getElementById('content').innerHTML = html;
      window._revealStats('.stats-bar-item');
      window._revealCards('.word-card');
    })
    .catch(function(e) {
      document.getElementById('content').innerHTML =
        '<div class="empty-state"><div class="icon">&#x26A0;</div><p>加载失败：' + e.message + '</p></div>';
    });

  function showWordQuestions(word) {
    var item = allWords.find(function(w) { return w.word === word; });
    if (!item) return;

    document.getElementById('panelTitle').textContent = '「' + word + '」相关错题（' + item.questionIds.length + '题）';
    document.getElementById('panelContent').innerHTML = '<div class="question-loading">加载中...</div>';
    document.getElementById('questionPanel').classList.add('show');

    fetch('/api/wrong-questions-by-ids', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ ids: item.questionIds })
    })
    .then(function(r) { return r.ok ? r.json() : null; })
    .then(function(questions) {
      if (!questions || questions.length === 0) {
        document.getElementById('panelContent').innerHTML = '<div class="question-loading">暂无题目数据</div>';
        return;
      }

      var html = '';
      questions.forEach(function(q, idx) {
        html += '<div class="question-item">';
        html += '<div class="q-source"><span class="q-num">第' + (idx+1) + '题</span>' + (q.source || '未知来源') + '</div>';
        html += '<div class="q-content">' + (q.content || '') + '</div>';
        if (q.options && q.options.length > 0) {
          html += '<div class="q-options">';
          q.options.forEach(function(opt, oi) {
            var cleanOpt = opt.replace(/<[^>]+>/g, '').trim();
            var correctAns = q.correctAnswer;
            if (correctAns && typeof correctAns === 'object') correctAns = correctAns.choice;
            if (correctAns === '0') correctAns = 'A';
            else if (correctAns === '1') correctAns = 'B';
            else if (correctAns === '2') correctAns = 'C';
            else if (correctAns === '3') correctAns = 'D';
            var isCorrect = ['A','B','C','D'][oi] === correctAns;
            html += '<div class="' + (isCorrect ? 'correct-opt' : '') + '">' + ['A','B','C','D'][oi] + '. ' + cleanOpt + '</div>';
          });
          html += '</div>';
        }
        if (q.solution) {
          html += '<div class="q-solution">';
          html += '<div class="q-solution-title">解析</div>';
          html += '<div>' + q.solution.replace(/<[^>]+>/g, '') + '</div>';
          html += '</div>';
        } else {
          html += '<div class="q-solution" style="color:#999;border-left-color:#ccc;">暂无解析</div>';
        }
        html += '</div>';
      });

      document.getElementById('panelContent').innerHTML = html;
      document.querySelectorAll('.question-item').forEach(function(el, i){
        el.style.animationDelay = (i * 0.06) + 's';
      });
    })
    .catch(function(e) {
      document.getElementById('panelContent').innerHTML = '<div class="question-loading">加载失败：' + e.message + '</div>';
    });
  }

  function closePanel() {
    document.getElementById('questionPanel').classList.remove('show');
  }

  document.getElementById('questionPanel').addEventListener('click', function(e) {
    if (e.target === this) closePanel();
  });
</script>
</body>
</html>
