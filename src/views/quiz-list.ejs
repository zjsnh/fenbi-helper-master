<html lang="zh">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>本地题库 · 粉笔助手</title>
  <link rel="stylesheet" href="/theme.css">
  <style>
    body { background: var(--paper); }

    /* ── Hero 区 ── */
    .page-hero {
      background:
        radial-gradient(ellipse at 20% 0%, rgba(0,102,204,0.05) 0%, transparent 50%),
        radial-gradient(ellipse at 80% 100%, rgba(90,155,230,0.03) 0%, transparent 50%);
      padding: 20px 0 8px;
      margin: -32px -24px 20px;
      padding-left: 24px;
      padding-right: 24px;
      position: relative;
      overflow: hidden;
    }
    .hero-row { display: flex; align-items: center; justify-content: space-between; position: relative; z-index: 1; }
    .hero-actions { display: flex; gap: 10px; }
    .upload-btn {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 9px 18px; background: var(--g-600, #0066cc); color: #fff;
      border: none; border-radius: 980px; font-size: 13px; font-weight: 600;
      cursor: pointer; transition: all 0.25s var(--ease-out); font-family: inherit;
      box-shadow: 0 2px 8px rgba(0,102,204,0.25);
      animation: fadeUp 0.5s var(--ease-out) 0.12s both;
    }
    .upload-btn:hover { background: var(--g-700, #0052a3); transform: translateY(-1px); box-shadow: 0 4px 14px rgba(0,102,204,0.35); }
    .upload-btn:active { transform: translateY(0); }

    /* ── 上传弹窗 ── */
    .modal-mask {
      position: fixed; inset: 0; background: rgba(10,22,40,0.45);
      display: none; align-items: center; justify-content: center; z-index: 1000;
      backdrop-filter: blur(2px);
    }
    .modal-mask.show { display: flex; animation: fadeIn 0.2s ease; }
    @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    .modal-card {
      background: var(--card, #fff); border-radius: 16px; padding: 28px 32px 24px;
      width: 560px; max-width: 92vw; max-height: 88vh; overflow-y: auto;
      box-shadow: 0 20px 60px rgba(0,0,0,0.18);
      animation: modalIn 0.3s var(--ease-spring, ease);
    }
    @keyframes modalIn { from { opacity: 0; transform: translateY(20px) scale(0.96); } to { opacity: 1; transform: translateY(0) scale(1); } }
    .modal-title { font-size: 18px; font-weight: 700; color: #0a1628; margin-bottom: 4px; font-family: var(--font-display); }
    .modal-sub { font-size: 13px; color: var(--text-ter); margin-bottom: 20px; line-height: 1.6; }
    .modal-sub code { background: var(--paper, #f7f8fa); padding: 1px 6px; border-radius: 4px; font-size: 12px; color: var(--g-700, #0052a3); }
    .modal-sub-link { color: var(--g-600, #0066cc); font-size: 12px; text-decoration: none; cursor: pointer; display: inline-block; margin-top: 6px; }
    .modal-sub-link:hover { color: var(--g-700, #0052a3); text-decoration: underline; }
    .modal-sub-detail { margin-top: 12px; padding-top: 12px; border-top: 0.5px dashed var(--border-light, #e2e8f0); }
    .modal-sub-detail.show { display: block; animation: fadeIn 0.25s ease; }
    .fmt-block { margin-bottom: 14px; }
    .fmt-block:last-child { margin-bottom: 0; }
    .fmt-title { font-size: 12px; font-weight: 700; color: var(--g-700, #0052a3); margin-bottom: 6px; letter-spacing: 0.2px; }
    .fmt-title .fmt-tag { display: inline-block; padding: 1px 6px; border-radius: 4px; background: var(--brand-50, #e6f0ff); color: var(--brand-600, #0066cc); font-size: 10px; margin-left: 6px; font-weight: 600; }
    .fmt-table { width: 100%; border-collapse: collapse; font-size: 11.5px; }
    .fmt-table th, .fmt-table td { padding: 4px 6px; text-align: left; border-bottom: 0.5px solid var(--border-light, #eef2f7); vertical-align: top; }
    .fmt-table th { background: var(--paper, #f7f8fa); color: var(--text-sec, #475569); font-weight: 600; font-size: 11px; }
    .fmt-table .col-field { font-family: var(--font-mono, monospace); color: var(--g-700, #0052a3); font-weight: 600; white-space: nowrap; }
    .fmt-table .col-req { color: #c0392b; font-size: 10px; font-weight: 700; }
    .fmt-table .col-opt { color: var(--text-ter, #94a3b8); font-size: 10px; }
    .fmt-table .col-desc { color: var(--text-sec, #475569); }
    .fmt-note { font-size: 11px; color: var(--text-ter, #94a3b8); margin-top: 6px; padding: 6px 10px; background: var(--paper, #f7f8fa); border-radius: 6px; line-height: 1.6; }
    .fmt-note code { background: #fff; padding: 1px 5px; }
    .form-group { margin-bottom: 16px; }
    .form-label { display: block; font-size: 13px; font-weight: 600; color: var(--text-sec, #475569); margin-bottom: 6px; }
    .form-input {
      width: 100%; padding: 9px 12px; border: 1px solid var(--border-light, #e2e8f0);
      border-radius: 8px; font-size: 14px; font-family: inherit; color: #0a1628;
      background: var(--card, #fff); transition: border-color 0.2s, box-shadow 0.2s;
      box-sizing: border-box;
    }
    .form-input:focus { outline: none; border-color: var(--g-400, #3399ff); box-shadow: 0 0 0 3px rgba(0,102,204,0.1); }
    .folder-pick {
      display: flex; align-items: center; gap: 10px; padding: 12px 14px;
      border: 1.5px dashed var(--border-light, #cbd5e1); border-radius: 10px;
      cursor: pointer; transition: all 0.2s; background: var(--paper, #f7f8fa);
    }
    .folder-pick:hover { border-color: var(--g-400, #3399ff); background: var(--brand-50, #e6f0ff); }
    .folder-pick.has-files { border-color: var(--g-500, #0066cc); border-style: solid; background: var(--brand-50, #e6f0ff); }
    .folder-pick-icon { font-size: 20px; }
    .folder-pick-text { font-size: 13px; color: var(--text-ter); flex: 1; }
    .folder-pick.has-files .folder-pick-text { color: var(--g-700, #0052a3); font-weight: 600; }
    .modal-actions { display: flex; gap: 10px; justify-content: flex-end; margin-top: 22px; }
    .btn-cancel {
      padding: 9px 18px; background: transparent; border: 1px solid var(--border-light, #e2e8f0);
      border-radius: 8px; font-size: 13px; color: var(--text-sec); cursor: pointer; font-family: inherit; transition: all 0.2s;
    }
    .btn-cancel:hover { background: var(--paper, #f7f8fa); }
    .btn-submit {
      padding: 9px 20px; background: var(--g-600, #0066cc); color: #fff; border: none;
      border-radius: 8px; font-size: 13px; font-weight: 600; cursor: pointer; font-family: inherit;
      transition: all 0.2s; box-shadow: 0 2px 8px rgba(0,102,204,0.25);
    }
    .btn-submit:hover { background: var(--g-700, #0052a3); }
    .btn-submit:disabled { background: var(--text-ter, #94a3b8); cursor: not-allowed; box-shadow: none; }
    .upload-result { margin-top: 14px; padding: 10px 14px; border-radius: 8px; font-size: 13px; line-height: 1.6; display: none; }
    .upload-result.show { display: block; animation: fadeIn 0.3s ease; }
    .upload-result.success { background: #ecfdf5; color: #065f46; border: 1px solid #a7f3d0; }
    .upload-result.error { background: #fef2f2; color: #991b1b; border: 1px solid #fecaca; }
    .upload-result.loading { background: var(--brand-50, #e6f0ff); color: var(--g-700, #0052a3); border: 1px solid var(--brand-100, #b8d4ff); }
    .page-hero::before {
      content: '';
      position: absolute;
      top: -30%; right: -15%;
      width: 80%; height: 160%;
      background: radial-gradient(circle at 50% 50%, rgba(0,102,204,0.03) 0%, transparent 40%);
      animation: heroDrift 12s ease-in-out infinite;
      pointer-events: none;
    }
    @keyframes heroDrift { 0%,100% { transform: translate(0,0); } 50% { transform: translate(-15px,15px); } }
    .hero-title { font-size: 22px; font-weight: 700; color: var(--text-900); letter-spacing: -0.3px; animation: titleRise 0.6s var(--ease-spring) both; position: relative; z-index: 1; }
    .hero-sub { font-size: 13px; color: var(--text-500); margin-top: 4px; animation: fadeUp 0.5s var(--ease-out) 0.08s both; position: relative; z-index: 1; }
    @keyframes titleRise { from { opacity: 0; transform: translateY(16px) scale(0.96); } to { opacity: 1; transform: translateY(0) scale(1); } }
    @keyframes fadeUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

    /* ── 分类卡片网格（第一级）── */
    .cat-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 16px;
    }
    .cat-card {
      background: var(--card);
      border: 0.5px solid var(--border-light);
      border-radius: 14px;
      padding: 24px;
      cursor: pointer;
      transition: all 0.3s var(--ease-out);
      position: relative;
      overflow: hidden;
      opacity: 0;
      transform: translateY(20px) scale(0.97);
    }
    .cat-card.visible {
      opacity: 1;
      transform: translateY(0) scale(1);
      transition: opacity 0.5s var(--ease-out), transform 0.5s var(--ease-spring),
                  border-color 0.3s, box-shadow 0.3s;
    }
    .cat-card:hover { border-color: var(--g-300); box-shadow: 0 4px 16px rgba(0,0,0,0.06); }
    .cat-card::before {
      content: '';
      position: absolute; top: 0; left: 0; right: 0; height: 3px;
      background: linear-gradient(90deg, var(--g-400), var(--g-600));
      transform: scaleX(0); transform-origin: left;
      transition: transform 0.5s var(--ease-out) 0.2s;
    }
    .cat-card.visible::before { transform: scaleX(1); }
    .cat-card.lr::before { background: linear-gradient(90deg, #f39c12, #e67e22); }
    .cat-card .cat-name { font-size: 18px; font-weight: 700; color: #0a1628; font-family: var(--font-display); margin-bottom: 8px; }
    .cat-card .cat-count { font-size: 36px; font-weight: 800; color: var(--g-600); margin-bottom: 4px; font-family: var(--font-mono); letter-spacing: -1px; }
    .cat-card.lr .cat-count { color: #e67e22; }
    .cat-card .cat-sub { font-size: 13px; color: var(--text-ter); }
    .cat-card .cat-uninstall {
      position: absolute; top: 16px; right: 16px;
      width: 28px; height: 28px; border-radius: 50%;
      background: transparent; border: 1px solid var(--border-light, #e2e8f0);
      color: var(--text-ter); font-size: 14px; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      transition: all 0.2s; opacity: 0;
    }
    .cat-card:hover .cat-uninstall { opacity: 1; }
    .cat-card .cat-uninstall:hover { background: #fef2f2; border-color: #fca5a5; color: #dc2626; }

    /* ── 题套列表页（第二级）── */
    .set-list-page { display: none; }
    .set-list-page.show { display: block; animation: pageSlideIn 0.4s var(--ease-out); }
    .category-page.hide { display: none; }
    @keyframes pageSlideIn { from { opacity: 0; transform: translateX(20px); } to { opacity: 1; transform: translateX(0); } }

    .back-btn {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 8px 16px; background: var(--card);
      border: 0.5px solid var(--border-light); border-radius: 980px;
      font-size: 13px; color: var(--text-sec);
      cursor: pointer; transition: all 0.25s var(--ease-out);
      margin-bottom: 20px; animation: fadeUp 0.4s var(--ease-out) both;
      font-family: inherit;
    }
    .back-btn:hover { border-color: var(--g-300); color: #0a1628; background: var(--brand-50); }

    .list-title {
      font-size: 20px; font-weight: 700; color: var(--text-900);
      margin-bottom: 4px; font-family: var(--font-display);
      animation: fadeUp 0.4s var(--ease-out) 0.06s both;
    }
    .list-sub-row {
      display: flex; align-items: center; justify-content: space-between;
      gap: 12px; margin-bottom: 20px;
      animation: fadeUp 0.4s var(--ease-out) 0.1s both;
    }
    .list-sub {
      font-size: 13px; color: var(--text-ter); flex: 1; min-width: 0;
    }
    .select-all-btn {
      flex-shrink: 0;
      padding: 6px 14px; font-size: 12px; font-weight: 600;
      color: var(--g-700, #0052a3); background: var(--card, #fff);
      border: 0.5px solid var(--border-light, #e2e8f0);
      border-radius: 980px; cursor: pointer; font-family: inherit;
      transition: all 0.2s; display: inline-flex; align-items: center; gap: 4px;
      white-space: nowrap;
    }
    .select-all-btn:hover {
      border-color: var(--g-400, #3399ff); color: var(--g-700, #0052a3);
      background: var(--brand-50, #e6f0ff);
    }
    .select-all-btn.all-selected {
      background: #fef0ee; color: #c0392b; border-color: #fca5a5;
    }
    .select-all-btn.all-selected:hover { background: #fde2df; }

    /* ── 题套列表（一列排列）── */
    .set-grid {
      display: flex;
      flex-direction: column;
      gap: 10px;
      margin-bottom: 16px;
      max-width: 720px;
    }
    .set-card {
      background: var(--card);
      border: 0.5px solid var(--border-light);
      border-radius: 12px;
      padding: 14px 18px;
      cursor: pointer;
      transition: border-color 0.25s, box-shadow 0.25s, transform 0.25s;
      display: flex;
      flex-direction: row;
      align-items: center;
      gap: 12px;
      text-decoration: none;
      color: inherit;
      opacity: 0;
      transform: translateY(8px);
    }
    .set-card.visible {
      opacity: 1;
      transform: translateY(0);
      transition: opacity 0.35s var(--ease-out), transform 0.35s var(--ease-out),
                  border-color 0.25s, box-shadow 0.25s;
    }
    .set-card:hover {
      border-color: var(--g-400);
      box-shadow: 0 4px 16px rgba(0,0,0,0.06);
      transform: translateY(-2px);
    }
    .set-card .set-head {
      display: flex; align-items: center; gap: 10px;
      flex: 1; min-width: 0;
    }
    .set-card .set-name {
      font-size: 15px; font-weight: 700; color: #0a1628;
      font-family: var(--font-display);
      flex: 0 1 auto; min-width: 0;
      overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .set-card .set-badge {
      font-size: 11px; padding: 2px 8px; border-radius: 10px;
      flex-shrink: 0;
    }
    .badge-fr { background: var(--brand-50, #e6f0ff); color: var(--brand-600, #0066cc); border: 1px solid var(--brand-100, #b8d4ff); }
    .badge-lr { background: #fff5e6; color: #b8860b; border: 1px solid #ffdbb0; }

    .set-card .set-meta {
      display: flex; gap: 10px; align-items: center;
      font-size: 12px; color: var(--text-ter);
      flex-shrink: 0;
    }
    .set-card .set-qcount {
      font-weight: 600; color: var(--g-700);
    }
    .set-card .set-progress {
      font-size: 11px; color: var(--brand-600, #0066cc);
      background: rgba(0,102,204,0.06);
      padding: 2px 8px; border-radius: 8px;
      white-space: nowrap;
    }
    .set-card .set-progress.done-lr {
      color: #b8860b; background: rgba(243,156,18,0.08);
    }
    .set-card .set-arrow {
      font-size: 16px; color: var(--text-ter);
      flex-shrink: 0;
      transition: transform 0.2s;
    }
    .set-card:hover .set-arrow { transform: translateX(3px); color: var(--g-600); }

    /* ── 勾选框 ── */
    .set-card .set-check {
      flex-shrink: 0; width: 18px; height: 18px;
      border: 1.5px solid var(--border-light, #cbd5e1);
      border-radius: 5px; background: var(--card, #fff);
      cursor: pointer; transition: all 0.2s;
      display: flex; align-items: center; justify-content: center;
      color: transparent; font-size: 12px; line-height: 1;
    }
    .set-card .set-check:hover { border-color: var(--g-400, #3399ff); }
    .set-card.checked .set-check {
      background: var(--g-600, #0066cc); border-color: var(--g-600, #0066cc); color: #fff;
    }

    /* ── 底部出题操作栏 ── */
    .custom-bar {
      position: fixed; bottom: 0; left: 0; right: 0; z-index: 100;
      background: var(--card, #fff); border-top: 0.5px solid var(--border-light, #e2e8f0);
      box-shadow: 0 -4px 20px rgba(0,0,0,0.08);
      padding: 14px 24px; display: none;
      align-items: center; gap: 16px;
      animation: barUp 0.3s var(--ease-out, ease);
    }
    @keyframes barUp { from { transform: translateY(100%); } to { transform: translateY(0); } }
    .custom-bar.show { display: flex; }
    .custom-bar .bar-info { flex: 1; font-size: 13px; color: var(--text-sec); }
    .custom-bar .bar-info strong { color: var(--g-700, #0052a3); font-weight: 700; }
    .custom-bar .bar-count {
      display: flex; align-items: center; gap: 8px;
      font-size: 13px; color: var(--text-sec);
    }
    .custom-bar .bar-count input {
      width: 64px; padding: 6px 10px; border: 1px solid var(--border-light, #e2e8f0);
      border-radius: 8px; font-size: 13px; font-family: var(--font-mono);
      text-align: center; color: #0a1628;
    }
    .custom-bar .bar-count input:focus { outline: none; border-color: var(--g-400, #3399ff); box-shadow: 0 0 0 3px rgba(0,102,204,0.1); }
    .custom-bar .bar-start {
      padding: 9px 24px; background: var(--g-600, #0066cc); color: #fff;
      border: none; border-radius: 980px; font-size: 13px; font-weight: 600;
      cursor: pointer; font-family: inherit; transition: all 0.2s;
      box-shadow: 0 2px 8px rgba(0,102,204,0.25);
    }
    .custom-bar .bar-start:hover { background: var(--g-700, #0052a3); }
    .custom-bar .bar-start:disabled { background: var(--text-ter, #94a3b8); cursor: not-allowed; box-shadow: none; }
    .custom-bar .bar-clear {
      padding: 9px 14px; background: transparent; border: 1px solid var(--border-light, #e2e8f0);
      border-radius: 980px; font-size: 12px; color: var(--text-sec); cursor: pointer; font-family: inherit;
    }
    .custom-bar .bar-clear:hover { background: var(--paper, #f7f8fa); }
  </style>
</head>
<body>

<div class="navbar">
  <a href="/history-category-complex" class="logo"><img src="/logo.svg" alt="">粉笔助手</a>
  <a href="/history-category-complex">练习记录</a>
  <a href="/history">列表视图</a>
  <a href="/wrong-questions">错题本</a>
  <a href="/word-frequency">词语统计</a>
  <a href="/quiz" class="active">本地题库</a>
  <a href="/shenlun-format">公文格式</a>
  <a href="/setup" style="margin-left:auto;">切换账号</a>
</div>

<div class="page-wrap" style="max-width:1100px; margin:0 auto; padding:32px 24px 60px;">
  <!-- 第一级：分类页 -->
  <div class="category-page" id="categoryPage">
    <div class="page-hero">
      <div class="hero-row">
        <div>
          <div class="hero-title">本地题库刷题</div>
          <div class="hero-sub">片段阅读 436 题 + 逻辑推理 600 题 · 做题计时 · 错题自动同步至练习记录与错题本</div>
        </div>
        <div class="hero-actions">
          <button class="upload-btn" onclick="openUploadModal()">+ 上传题库</button>
        </div>
      </div>
    </div>

    <div class="cat-grid" id="catGrid"></div>
  </div>

  <!-- 第二级：题套列表页 -->
  <div class="set-list-page" id="setListPage">
    <button class="back-btn" onclick="backToCategory()">&#x2190; 返回分类</button>
    <div class="list-title" id="listTitle"></div>
    <div class="list-sub-row">
      <div class="list-sub" id="listSub"></div>
      <button class="select-all-btn" id="selectAllBtn" onclick="toggleSelectAll()" style="display:none;">全选</button>
    </div>
    <div class="set-grid" id="setGrid"></div>
  </div>
</div>

<!-- 底部自定义出题操作栏 -->
<div class="custom-bar" id="customBar">
  <div class="bar-info">已选 <strong id="selSetCount">0</strong> 套 · 共 <strong id="selQCount">0</strong> 题</div>
  <div class="bar-count">
    <span>出题数量</span>
    <input type="number" id="customCount" min="1" placeholder="全部">
    <span>留空=全部</span>
  </div>
  <button class="bar-clear" onclick="clearSelection()">清空</button>
  <button class="bar-start" id="customStart" onclick="startCustomQuiz()" disabled>开始练习</button>
</div>

<!-- 上传题库弹窗 -->
<div class="modal-mask" id="uploadModal" onclick="if(event.target===this)closeUploadModal()">
  <div class="modal-card">
    <div class="modal-title">上传本地题库</div>
    <div class="modal-sub">
      选择包含 <code>.xlsx</code> 或 <code>.apkg</code> 文件的文件夹，系统会按文件自动拆分题套，文件夹名作为分类名保留显示。
      <a class="modal-sub-link" onclick="toggleFormatDetail()">查看详细格式规范 ▾</a>
      <div class="modal-sub-detail" id="formatDetail" style="display:none;">
        <div class="fmt-block">
          <div class="fmt-title">一、xlsx 表头规范 <span class="fmt-tag">首行必需</span></div>
          <table class="fmt-table">
            <thead>
              <tr><th style="width:24%;">字段名</th><th style="width:14%;">必填</th><th>说明</th></tr>
            </thead>
            <tbody>
              <tr><td class="col-field">题干</td><td class="col-req">必填</td><td class="col-desc">题目正文（也支持列名「题目」）</td></tr>
              <tr><td class="col-field">选项A ~ 选项D</td><td class="col-req">必填</td><td class="col-desc">至少 4 列；多选可扩展到「选项E」「选项F」</td></tr>
              <tr><td class="col-field">答案</td><td class="col-req">必填</td><td class="col-desc">单选填 <code>A</code>/<code>B</code>/<code>C</code>/<code>D</code>；多选填字母组合如 <code>ABC</code>，顺序无关，系统自动排序去重</td></tr>
              <tr><td class="col-field">题型</td><td class="col-opt">选填</td><td class="col-desc">填「单选」「多选」「多项选择」；留空默认按单选处理</td></tr>
              <tr><td class="col-field">解析</td><td class="col-opt">选填</td><td class="col-desc">题目解析文本，结果页会自动压缩空白</td></tr>
              <tr><td class="col-field">知识点</td><td class="col-opt">选填</td><td class="col-desc">考点标签，结果页以小标签显示</td></tr>
              <tr><td class="col-field">图片URL</td><td class="col-opt">选填</td><td class="col-desc">题目配图链接，http/https 开头</td></tr>
              <tr><td class="col-field">题号</td><td class="col-opt">选填</td><td class="col-desc">仅记录用，不影响加载</td></tr>
            </tbody>
          </table>
          <div class="fmt-note">
            提示：列名需严格匹配（区分中文），多余列会被忽略；每个 <code>.xlsx</code> 文件即一个题套，文件名取作题套名，建议含数字便于排序（如「专项练习01.xlsx」）。
          </div>
        </div>

        <div class="fmt-block">
          <div class="fmt-title">二、apkg 字段规范 <span class="fmt-tag">Anki 导出</span></div>
          <table class="fmt-table">
            <thead>
              <tr><th style="width:8%;">序</th><th style="width:20%;">字段</th><th>说明</th></tr>
            </thead>
            <tbody>
              <tr><td>1</td><td class="col-field">题型</td><td class="col-desc">「单选」/「多选」/「多项选择」</td></tr>
              <tr><td>2</td><td class="col-field">题号</td><td class="col-desc">题号文本（选填）</td></tr>
              <tr><td>3</td><td class="col-field">题干</td><td class="col-desc">题目正文</td></tr>
              <tr><td>4</td><td class="col-field">选项</td><td class="col-desc">用 <code>&lt;br&gt;</code> 分隔：<code>A. 选项一&lt;br&gt;B. 选项二&lt;br&gt;C. 选项三&lt;br&gt;D. 选项四</code></td></tr>
              <tr><td>5</td><td class="col-field">答案</td><td class="col-desc">单选填单字母；多选填字母组合</td></tr>
              <tr><td>6</td><td class="col-field">解析</td><td class="col-desc">解析文本</td></tr>
              <tr><td>7</td><td class="col-field">知识点</td><td class="col-desc">考点标签</td></tr>
            </tbody>
          </table>
          <div class="fmt-note">
            apkg 是 Anki 导出包（ZIP 内含 <code>collection.anki2</code> SQLite 数据库），7 个字段按 <code>\x1f</code> 分隔符固定顺序存储于 notes 表的 flds 列；多个 apkg 文件即多个题套。
          </div>
        </div>

        <div class="fmt-block">
          <div class="fmt-title">三、文件与文件夹</div>
          <table class="fmt-table">
            <thead>
              <tr><th style="width:24%;">项目</th><th>说明</th></tr>
            </thead>
            <tbody>
              <tr><td class="col-field">文件夹名</td><td class="col-desc">作为分类名原样保留，不再自动加时间戳或重命名</td></tr>
              <tr><td class="col-field">文件格式</td><td class="col-desc">同一文件夹内 <code>.xlsx</code> 与 <code>.apkg</code> 不要混放，按主要格式上传</td></tr>
              <tr><td class="col-field">文件命名</td><td class="col-desc">建议含数字段，如「第01套.xlsx」「专项02.apkg」，系统按末尾数字排序</td></tr>
              <tr><td class="col-field">分类名（可选）</td><td class="col-desc">表单填写后将覆盖文件夹名作为分类显示名；留空则用文件夹名</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <div class="form-group">
      <label class="form-label">分类名称（可选，留空则自动命名）</label>
      <input type="text" class="form-input" id="uploadSource" placeholder="例如：图形推理专项" maxlength="30">
    </div>

    <div class="form-group">
      <label class="form-label">选择题库文件夹</label>
      <label class="folder-pick" id="folderPick" for="folderInput">
        <span class="folder-pick-icon">&#128193;</span>
        <span class="folder-pick-text" id="folderPickText">点击选择文件夹（含 xlsx / apkg）</span>
        <input type="file" id="folderInput" webkitdirectory directory multiple style="display:none">
      </label>
    </div>

    <div class="upload-result" id="uploadResult"></div>

    <div class="modal-actions">
      <button class="btn-cancel" onclick="closeUploadModal()">取消</button>
      <button class="btn-submit" id="uploadSubmit" onclick="submitUpload()" disabled>开始上传</button>
    </div>
  </div>
</div>

<script>
// 数据：所有分类与题套（服务端渲染注入）
var SOURCES = <%- JSON.stringify(sources) %>;

// ── 渲染分类页 ──
function renderCategory() {
  var html = '';
  SOURCES.forEach(function(src, idx) {
    var isLr = src.sets.length > 0 && src.sets[0].setId.indexOf('lr_') === 0;
    var cls = 'cat-card' + (isLr ? ' lr' : '');
    html += '<div class="' + cls + '" onclick="showSets(' + idx + ')">';
    // 上传的题库显示卸载按钮
    if (src.uploaded) {
      html += '<button class="cat-uninstall" title="卸载此题库" onclick="event.stopPropagation(); uninstallQuiz(\'' + escapeAttr(src.name) + '\')">&#x2715;</button>';
    }
    html += '<div class="cat-name">' + src.name + '</div>';
    html += '<div class="cat-count">' + src.sets.length + '</div>';
    html += '<div class="cat-sub">共 ' + src.sets.length + ' 套 · ' + src.totalQ + ' 题</div>';
    html += '</div>';
  });
  document.getElementById('catGrid').innerHTML = html;

  // 入场动画
  setTimeout(function(){
    document.querySelectorAll('.cat-card').forEach(function(el, i){
      setTimeout(function(){ el.classList.add('visible'); }, i * 120);
    });
  }, 100);
}

// HTML 属性转义
function escapeAttr(s) {
  return String(s).replace(/'/g, "\\'").replace(/"/g, '&quot;');
}

// ── 勾选状态管理 ──
// selectedSets: { setId -> questionCount }
var selectedSets = {};

function toggleSetCheck(el, setId, qCount) {
  var card = el.closest('.set-card');
  if (selectedSets[setId]) {
    delete selectedSets[setId];
    card.classList.remove('checked');
  } else {
    selectedSets[setId] = qCount;
    card.classList.add('checked');
  }
  updateCustomBar();
  updateSelectAllBtn();
}

// 全选 / 取消全选：根据当前题套列表的勾选状态切换
function toggleSelectAll() {
  var cards = document.querySelectorAll('#setGrid .set-card');
  if (cards.length === 0) return;
  var allChecked = true;
  cards.forEach(function(c) {
    if (!c.classList.contains('checked')) allChecked = false;
  });
  if (allChecked) {
    // 全部已选 → 取消全选（仅清空当前分类下的勾选）
    cards.forEach(function(c) {
      var sid = c.getAttribute('data-set-id');
      delete selectedSets[sid];
      c.classList.remove('checked');
    });
  } else {
    // 未全选 → 全选当前分类下所有题套
    cards.forEach(function(c) {
      var sid = c.getAttribute('data-set-id');
      var qc = parseInt(c.getAttribute('data-q-count') || '0', 10);
      selectedSets[sid] = qc;
      c.classList.add('checked');
    });
  }
  updateCustomBar();
  updateSelectAllBtn();
}

// 更新全选按钮文字与状态：无题套时隐藏；全选时显示「取消全选」红色态；否则显示「全选」
function updateSelectAllBtn() {
  var btn = document.getElementById('selectAllBtn');
  if (!btn) return;
  var cards = document.querySelectorAll('#setGrid .set-card');
  if (cards.length === 0) {
    btn.style.display = 'none';
    return;
  }
  btn.style.display = 'inline-flex';
  var checkedCount = 0;
  cards.forEach(function(c) { if (c.classList.contains('checked')) checkedCount++; });
  if (checkedCount === cards.length) {
    btn.textContent = '取消全选';
    btn.classList.add('all-selected');
  } else {
    btn.textContent = '全选（' + cards.length + '）';
    btn.classList.remove('all-selected');
  }
}

function restoreSetChecks() {
  document.querySelectorAll('#setGrid .set-card').forEach(function(card) {
    var sid = card.getAttribute('data-set-id');
    if (selectedSets[sid]) card.classList.add('checked');
  });
  updateSelectAllBtn();
}

function clearSelection() {
  selectedSets = {};
  document.querySelectorAll('.set-card.checked').forEach(function(el) { el.classList.remove('checked'); });
  updateCustomBar();
  updateSelectAllBtn();
}

function updateCustomBar() {
  var ids = Object.keys(selectedSets);
  var setCount = ids.length;
  var qCount = ids.reduce(function(sum, id) { return sum + (selectedSets[id] || 0); }, 0);
  document.getElementById('selSetCount').textContent = setCount;
  document.getElementById('selQCount').textContent = qCount;
  var bar = document.getElementById('customBar');
  var btn = document.getElementById('customStart');
  if (setCount > 0) {
    bar.classList.add('show');
    btn.disabled = false;
  } else {
    bar.classList.remove('show');
    btn.disabled = true;
  }
}

function startCustomQuiz() {
  var ids = Object.keys(selectedSets);
  if (ids.length === 0) return;
  var countInput = document.getElementById('customCount').value.trim();
  var url = '/quiz/custom?setIds=' + ids.join(',');
  if (countInput && parseInt(countInput) > 0) {
    url += '&count=' + parseInt(countInput);
  }
  window.location.href = url;
}

// 卸载题库
function uninstallQuiz(source) {
  if (!confirm('确定要卸载题库「' + source + '」吗？\n该操作会删除已上传的文件，且不可恢复。')) return;
  fetch('/api/quiz/uninstall', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ source: source })
  }).then(function(r) { return r.json(); }).then(function(res) {
    if (res.code === 0) {
      alert(res.message);
      window.location.reload();
    } else {
      alert('卸载失败：' + (res.message || '未知错误'));
    }
  }).catch(function(e) {
    alert('卸载失败：' + e.message);
  });
}

// ── 显示某分类下的题套列表 ──
function showSets(idx) {
  var src = SOURCES[idx];
  if (!src) return;

  document.getElementById('categoryPage').classList.add('hide');
  document.getElementById('setListPage').classList.add('show');

  document.getElementById('listTitle').textContent = src.name;
  document.getElementById('listSub').textContent = '共 ' + src.sets.length + ' 套题 · ' + src.totalQ + ' 题，点击下方任意一套进入做题';

  var isLr = src.sets.length > 0 && src.sets[0].setId.indexOf('lr_') === 0;
  var html = '';
  src.sets.forEach(function(s) {
    var progressHtml = '';
    if (s.doneCount > 0) {
      var pcls = 'set-progress' + (isLr ? ' done-lr' : '');
      progressHtml = '<span class="' + pcls + '">做过 ' + s.doneCount + ' 次 · 最佳 ' + s.bestRate + '%</span>';
    } else {
      progressHtml = '<span class="set-progress">未做</span>';
    }
    html += '<a class="set-card" href="/quiz/' + s.setId + '" data-set-id="' + s.setId + '" data-q-count="' + s.questionCount + '">';
    html += '<div class="set-check" onclick="event.preventDefault(); event.stopPropagation(); toggleSetCheck(this, \'' + s.setId + '\', ' + s.questionCount + ')" title="勾选后可自定义出题">&#10003;</div>';
    html += '<div class="set-head">';
    html += '<div class="set-name" title="' + s.setName + '">' + s.setName + '</div>';
    html += '<span class="set-badge ' + (isLr ? 'badge-lr' : 'badge-fr') + '">' + (isLr ? '逻辑' : '阅读') + '</span>';
    html += '</div>';
    html += '<div class="set-meta">';
    html += '<span class="set-qcount">' + s.questionCount + ' 题</span>';
    html += progressHtml;
    html += '</div>';
    html += '<div class="set-arrow">→</div>';
    html += '</a>';
  });
  document.getElementById('setGrid').innerHTML = html;

  // 恢复该分类下已勾选状态
  restoreSetChecks();

  // 入场动画
  setTimeout(function(){
    document.querySelectorAll('#setGrid .set-card').forEach(function(el, i){
      setTimeout(function(){ el.classList.add('visible'); }, i * 40);
    });
  }, 100);
}

// ── 返回分类页 ──
function backToCategory() {
  document.getElementById('setListPage').classList.remove('show');
  document.getElementById('categoryPage').classList.remove('hide');
  // 隐藏底部操作栏
  document.getElementById('customBar').classList.remove('show');
}

// 初始化
renderCategory();

// ── 上传题库相关 ──
var selectedFiles = [];

function openUploadModal() {
  document.getElementById('uploadModal').classList.add('show');
  resetUploadForm();
}

function closeUploadModal() {
  document.getElementById('uploadModal').classList.remove('show');
}

function resetUploadForm() {
  selectedFiles = [];
  document.getElementById('uploadSource').value = '';
  document.getElementById('folderInput').value = '';
  document.getElementById('folderPick').classList.remove('has-files');
  document.getElementById('folderPickText').textContent = '点击选择文件夹（含 xlsx / apkg）';
  document.getElementById('uploadSubmit').disabled = true;
  hideResult();
  // 默认折叠格式详情
  var detail = document.getElementById('formatDetail');
  if (detail) detail.style.display = 'none';
}

function toggleFormatDetail() {
  var detail = document.getElementById('formatDetail');
  if (!detail) return;
  var shown = detail.style.display !== 'none';
  detail.style.display = shown ? 'none' : 'block';
  var link = event && event.target ? event.target : null;
  if (link) link.textContent = shown ? '查看详细格式规范 ▾' : '收起格式规范 ▴';
}

function hideResult() {
  var el = document.getElementById('uploadResult');
  el.className = 'upload-result';
  el.textContent = '';
}

function showResult(type, msg) {
  var el = document.getElementById('uploadResult');
  el.className = 'upload-result show ' + type;
  el.innerHTML = msg;
}

// 监听文件夹选择
document.getElementById('folderInput').addEventListener('change', function(e) {
  var allFiles = e.target.files;
  // 仅保留 xlsx / apkg
  var valid = [];
  for (var i = 0; i < allFiles.length; i++) {
    var n = allFiles[i].name.toLowerCase();
    if (n.endsWith('.xlsx') || n.endsWith('.apkg')) {
      valid.push(allFiles[i]);
    }
  }
  selectedFiles = valid;
  var pick = document.getElementById('folderPick');
  var text = document.getElementById('folderPickText');
  var btn = document.getElementById('uploadSubmit');
  if (valid.length === 0) {
    pick.classList.remove('has-files');
    text.textContent = '未发现 xlsx/apkg 文件，请重新选择';
    btn.disabled = true;
  } else {
    pick.classList.add('has-files');
    var xlsxN = valid.filter(function(f){ return f.name.toLowerCase().endsWith('.xlsx'); }).length;
    var apkgN = valid.length - xlsxN;
    text.textContent = '已选 ' + valid.length + ' 个文件（xlsx ' + xlsxN + ' / apkg ' + apkgN + '）';
    btn.disabled = false;
  }
  hideResult();
});

function submitUpload() {
  if (selectedFiles.length === 0) return;
  var btn = document.getElementById('uploadSubmit');
  btn.disabled = true;
  btn.textContent = '上传中...';
  showResult('loading', '正在上传 ' + selectedFiles.length + ' 个文件，请稍候...');

  var fd = new FormData();
  var source = document.getElementById('uploadSource').value.trim();
  // 从第一个文件的 webkitRelativePath 提取原始文件夹名
  var origFolder = '';
  if (selectedFiles[0].webkitRelativePath) {
    origFolder = selectedFiles[0].webkitRelativePath.split('/')[0];
  }
  fd.append('source', source);
  fd.append('folderName', origFolder);
  selectedFiles.forEach(function(f) {
    fd.append('files', f, f.name);
  });

  var xhr = new XMLHttpRequest();
  xhr.open('POST', '/api/quiz/upload-folder');
  xhr.onload = function() {
    btn.disabled = false;
    btn.textContent = '开始上传';
    try {
      var res = JSON.parse(xhr.responseText);
      if (xhr.status === 200 && res.code === 0) {
        showResult('success', '✓ ' + res.message + '<br>分类：<strong>' + res.data.source + '</strong>，<a href="/quiz" style="color:inherit;text-decoration:underline;">点击刷新页面查看</a>');
        // 2 秒后自动刷新
        setTimeout(function() { window.location.reload(); }, 2000);
      } else {
        showResult('error', '✗ ' + (res.message || '上传失败'));
      }
    } catch (e) {
      showResult('error', '✗ 解析响应失败：' + xhr.responseText);
    }
  };
  xhr.onerror = function() {
    btn.disabled = false;
    btn.textContent = '开始上传';
    showResult('error', '✗ 网络错误，上传失败');
  };
  xhr.send(fd);
}
</script>
</body>
</html>
