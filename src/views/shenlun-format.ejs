    { name:'宣传稿', fmt:'full', scope:'用于宣传政策、推广经验、动员群众的文稿。语言生动通俗，有感染力。', elements:['标题','称谓','正文','落款'], framework:'宣传背景 → 核心内容 → 典型案例 → 号召行动。', structure:['标题：醒目，概括宣传主题（可灵活拟写）','称谓：宣传对象，顶格','正文：引入话题 → 核心内容（政策/经验）→ 号召行动','落款：宣传单位 + 日期'], demo:'【标题居中】\n××（主题型标题）\n\n【称谓】\n各位居民：\n\n【正文】\n  ××（引入话题）。\n  一、什么是××\n  ……\n  二、为什么要××\n  ……\n  三、怎么做××\n  ……\n  让我们一起行动起来，××！\n\n【落款】\n            ××\n           2026年×月×日' },
    { name:'短评', fmt:'special', scope:'对某一事件、现象发表简短评论的文章。评论类公文，行文结构为"标题+正文"。', elements:['标题','正文'], framework:'引述事件 → 分析评论 → 表明态度/提出建议。', structure:['标题：观点鲜明，突出评论对象，居中（不加文种）','正文：引述事件 → 分析评论 → 表明态度 → 提出建议','注意：标题+正文，无称谓、无落款；篇幅短小'], demo:'【标题居中】\n××（观点型标题）\n\n【正文】\n  近日，××（引述事件）。这一现象引发××关注。\n  之所以××，是因为××（分析原因）。这不仅××，更××（指出危害/意义）。\n  因此，××（对策建议）。只有××，才能××。' },
    { name:'导学材料', fmt:'special', scope:'引导学习用的材料，把材料内容按一定逻辑捋顺，条分缕析写清楚。', elements:['标题','正文'], framework:'开头 → 主体 → 结尾，按材料逻辑梳理。', structure:['标题：包含题目主题词，居中','正文：开头 → 主体（分条）→ 结尾','注意：标题+正文，与一般公文正文书写格式类似'], demo:'【标题居中】\n关于××的导学材料\n\n【正文】\n  一、××的基本内涵\n  ……\n  二、××的重要意义\n  ……\n  三、××的实践要求\n  ……' }
  ]
};

var FMT_LABEL = { full:{text:'完整格式',cls:'fmt-full'}, partial:{text:'不完整格式',cls:'fmt-partial'}, special:{text:'特殊格式',cls:'fmt-special'} };

// 统计
var totalCount = 0;
Object.keys(DATA).forEach(function(k){ totalCount += DATA[k].length; });
document.getElementById('total-count').textContent = totalCount;

// 渲染分类卡片（顺序：事务文书、应用文、法定公文）
function renderCategoryPage() {
  var grid = document.getElementById('catGrid');
  var html = '';
  var ORDER = ['事务文书', '应用文', '法定公文'];
  ORDER.forEach(function(cat, idx) {
    var count = DATA[cat].length;
    var note = cat === '法定公文' ? '（考查较少）' : '';
    html += '<div class="cat-card" onclick="showDocList(\'' + cat + '\')">' +
      '<div class="cat-name">' + cat + '<span style="font-size:12px;color:var(--text-ter);font-weight:400;margin-left:6px;">' + note + '</span></div>' +
      '<div class="cat-count">' + count + '</div>' +
      '<div class="cat-sub">点击查看文种详情</div>' +
      '</div>';
  });
  grid.innerHTML = html;
  // 渐入动画
  var cards = grid.querySelectorAll('.cat-card');
  cards.forEach(function(c, i) {
    setTimeout(function() { c.classList.add('visible'); }, i * 80);
  });
}

// 显示文种列表
function showDocList(cat) {
  document.getElementById('categoryPage').classList.add('hide');
  var page = document.getElementById('docListPage');
  page.classList.add('show');

  document.getElementById('docListTitle').textContent = cat + '（' + DATA[cat].length + ' 种）';

  var grid = document.getElementById('docGrid');
  var html = '';
  DATA[cat].forEach(function(d, i) {
    var fmt = FMT_LABEL[d.fmt];
    html += '<div class="doc-card" onclick="showDetail(' + i + ',\'' + cat + '\')">' +
      '<div class="doc-name">' + d.name + '</div>' +
      '<span class="doc-fmt-badge ' + fmt.cls + '">' + fmt.text + '</span>' +
      '<div class="doc-scope">' + d.scope + '</div>' +
      '</div>';
  });
  grid.innerHTML = html;
  // 渐入动画
  var cards = grid.querySelectorAll('.doc-card');
  cards.forEach(function(c, i) {
    setTimeout(function() { c.classList.add('visible'); }, i * 40);
  });
}

// 返回分类
function showCategory() {
  document.getElementById('docListPage').classList.remove('show');
  document.getElementById('categoryPage').classList.remove('hide');
}

// 显示详情面板
function showDetail(idx, cat) {
  var d = DATA[cat][idx];
  var fmt = FMT_LABEL[d.fmt];
  var html = '<div class="detail-header">' +
    '<h3>' + d.name + '<span class="doc-fmt-badge ' + fmt.cls + '">' + fmt.text + '</span></h3>' +
    '<button class="close-btn" onclick="closeDetail()">&times;</button>' +
    '</div>' +
    '<div class="detail-section"><div class="detail-section-title">适用范围</div><div class="detail-section-content">' + d.scope + '</div></div>' +
    '<div class="detail-section"><div class="detail-section-title">格式要素</div><div class="fmt-elements">' +
      d.elements.map(function(e){ return '<span class="fmt-el">' + e + '</span>'; }).join('') +
    '</div></div>' +
    '<div class="detail-section"><div class="detail-section-title">基本框架</div><div class="detail-section-content">' + d.framework + '</div></div>' +
    '<div class="detail-section"><div class="detail-section-title">结构要素</div><div class="detail-section-content"><ul>' +
      d.structure.map(function(s){ return '<li>' + s + '</li>'; }).join('') +
    '</ul></div></div>' +
    '<div class="detail-section"><div class="detail-section-title">格式示意</div><div class="format-demo">' + formatDemo(d.demo) + '</div></div>';

  document.getElementById('detailInner').innerHTML = html;
  document.getElementById('detailPanel').classList.add('show');
}

function closeDetail() {
  document.getElementById('detailPanel').classList.remove('show');
}

function formatDemo(text) {
  return text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/【([^】]+)】/g, '<span class="bold">【$1】</span>');
}

renderCategoryPage();
</script>
</body>
</html>
