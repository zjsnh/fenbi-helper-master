<html lang="zh">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>申论公文格式 · 粉笔助手</title>
  <link rel="stylesheet" href="/theme.css">
  <style>
    body { background: var(--paper); }

    /* ── Hero 区 ── */
    .page-hero {
      background:
        radial-gradient(ellipse at 20% 0%, rgba(0,102,204,0.05) 0%, transparent 50%),
        radial-gradient(ellipse at 80% 100%, rgba(90,155,230,0.03) 0%, transparent 50%);
      padding: 20px 0 8px;
      margin: -32px -24px 20px;
      padding-left: 24px;
      padding-right: 24px;
      position: relative;
      overflow: hidden;
    }
    .page-hero::before {
      content: '';
      position: absolute;
      top: -30%; right: -15%;
      width: 80%; height: 160%;
      background: radial-gradient(circle at 50% 50%, rgba(0,102,204,0.03) 0%, transparent 40%);
      animation: heroDrift 12s ease-in-out infinite;
      pointer-events: none;
    }
    @keyframes heroDrift { 0%,100% { transform: translate(0,0); } 50% { transform: translate(-15px,15px); } }
    .hero-title { font-size: 22px; font-weight: 700; color: var(--text-900); letter-spacing: -0.3px; animation: titleRise 0.6s var(--ease-spring) both; position: relative; z-index: 1; }
    .hero-sub { font-size: 13px; color: var(--text-500); margin-top: 4px; animation: fadeUp 0.5s var(--ease-out) 0.08s both; position: relative; z-index: 1; }
    @keyframes titleRise { from { opacity: 0; transform: translateY(16px) scale(0.96); } to { opacity: 1; transform: translateY(0) scale(1); } }
    @keyframes fadeUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

    /* ── 统计栏 ── */
    .stats-bar { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 24px; }
    .stats-bar-item {
      background: var(--card); border: 0.5px solid var(--border-light);
      border-radius: 10px; padding: 12px 20px;
      font-size: 13px; color: var(--text-sec);
    }
    .stats-bar-item b { color: #0a1628; font-weight: 700; font-size: 16px; }

    /* ── 格式说明 ── */
    .format-guide {
      background: var(--card); border: 0.5px solid var(--border-light);
      border-radius: 10px; padding: 14px 20px; margin-bottom: 24px;
      font-size: 13px; line-height: 1.8; color: var(--text-sec);
    }
    .format-guide b { color: var(--brand-600, #0066cc); }
    .format-guide .tag { display: inline-block; padding: 1px 7px; border-radius: 8px; font-size: 11px; margin: 0 2px; }
    .tag-full { background: var(--brand-50, #e6f0ff); color: var(--brand-700, #004499); border: 1px solid var(--brand-100, #b8d4ff); }
    .tag-partial { background: #fff5e6; color: #b8860b; border: 1px solid #ffdbb0; }
    .tag-special { background: #e6f7ff; color: #096dd9; border: 1px solid #b8dbff; }

    /* ── 分类卡片网格 ── */
    .cat-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 16px;
    }
    .cat-card {
      background: var(--card);
      border: 0.5px solid var(--border-light);
      border-radius: 14px;
      padding: 24px;
      cursor: pointer;
      transition: all 0.3s var(--ease-out);
      position: relative;
      overflow: hidden;
      opacity: 0;
      transform: translateY(20px) scale(0.97);
    }
    .cat-card.visible {
      opacity: 1;
      transform: translateY(0) scale(1);
      transition: opacity 0.5s var(--ease-out), transform 0.5s var(--ease-spring),
                  border-color 0.3s, box-shadow 0.3s;
    }
    .cat-card:hover { border-color: var(--g-300); box-shadow: 0 4px 16px rgba(0,0,0,0.06); }
    .cat-card::before {
      content: '';
      position: absolute; top: 0; left: 0; right: 0; height: 3px;
      background: linear-gradient(90deg, var(--g-400), var(--g-600));
      transform: scaleX(0); transform-origin: left;
      transition: transform 0.5s var(--ease-out) 0.2s;
    }
    .cat-card.visible::before { transform: scaleX(1); }
    .cat-card .cat-name { font-size: 18px; font-weight: 700; color: #0a1628; font-family: var(--font-display); margin-bottom: 8px; }
    .cat-card .cat-count { font-size: 36px; font-weight: 800; color: var(--g-600); margin-bottom: 4px; font-family: var(--font-mono); letter-spacing: -1px; }
    .cat-card .cat-sub { font-size: 13px; color: var(--text-ter); }

    /* ── 文种列表页 ── */
    .doc-list-page { display: none; }
    .doc-list-page.show { display: block; animation: pageSlideIn 0.4s var(--ease-out); }
    .category-page.hide { display: none; }
    @keyframes pageSlideIn { from { opacity: 0; transform: translateX(20px); } to { opacity: 1; transform: translateX(0); } }

    .back-btn {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 8px 16px; background: var(--card);
      border: 0.5px solid var(--border-light); border-radius: 980px;
      font-size: 13px; color: var(--text-sec);
      cursor: pointer; transition: all 0.25s var(--ease-out);
      margin-bottom: 20px; animation: fadeUp 0.4s var(--ease-out) both;
    }
    .back-btn:hover { border-color: var(--g-300); color: #0a1628; background: var(--brand-50); }

    .list-title { font-size: 20px; font-weight: 700; color: var(--text-900); margin-bottom: 20px; font-family: var(--font-display); animation: fadeUp 0.4s var(--ease-out) 0.06s both; }

    /* ── 文种卡片网格 ── */
    .doc-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 12px;
    }
    .doc-card {
      background: var(--card);
      border: 0.5px solid var(--border-light);
      border-radius: 12px;
      padding: 16px 18px;
      cursor: pointer;
      transition: border-color 0.25s, box-shadow 0.25s;
      opacity: 0;
      transform: translateY(12px);
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .doc-card.visible {
      opacity: 1;
      transform: translateY(0);
      transition: opacity 0.35s var(--ease-out), transform 0.35s var(--ease-out),
                  border-color 0.25s, box-shadow 0.25s;
    }
    .doc-card:hover { border-color: var(--g-300); box-shadow: 0 2px 12px rgba(0,0,0,0.05); }
    .doc-card .doc-name { font-size: 15px; font-weight: 700; color: #0a1628; font-family: var(--font-display); }
    .doc-card .doc-fmt-badge { font-size: 11px; padding: 2px 8px; border-radius: 10px; border: 1px solid; align-self: flex-start; }
    .fmt-full { background: var(--brand-50, #e6f0ff); color: var(--brand-600, #0066cc); border-color: var(--brand-100, #b8d4ff); }
    .fmt-partial { background: #fff5e6; color: #b8860b; border-color: #ffdbb0; }
    .fmt-special { background: #e6f7ff; color: #096dd9; border-color: #b8dbff; }
    .doc-card .doc-scope { font-size: 12px; color: var(--text-ter); line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

    /* ── 详情面板 ── */
    .detail-panel {
      display: none;
      position: fixed; top: 0; left: 0; right: 0; bottom: 0;
      background: rgba(0,0,0,0.4);
      z-index: 1000;
      overflow-y: auto;
      padding: 40px 20px;
      animation: overlayFadeIn 0.25s var(--ease-out);
    }
    .detail-panel.show { display: block; }
    @keyframes overlayFadeIn { from { opacity: 0; } to { opacity: 1; } }
    .detail-panel-inner {
      max-width: 720px;
      margin: 0 auto;
      background: var(--card);
      border-radius: 16px;
      padding: 24px;
      box-shadow: 0 12px 40px rgba(0,0,0,0.15);
      max-height: 80vh;
      overflow-y: auto;
      animation: panelPop 0.35s var(--ease-spring);
    }
    @keyframes panelPop { from { opacity: 0; transform: scale(0.95) translateY(12px); } to { opacity: 1; transform: scale(1) translateY(0); } }
    .detail-header {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 16px; padding-bottom: 12px;
      border-bottom: 0.5px solid var(--border-light);
      position: sticky; top: 0; background: var(--card); z-index: 1;
    }
    .detail-header h3 { margin: 0; font-size: 18px; font-weight: 700; color: #0a1628; display: flex; align-items: center; gap: 10px; }
    .detail-header .close-btn { font-size: 20px; cursor: pointer; color: var(--text-ter); background: none; border: none; padding: 4px 8px; border-radius: 8px; transition: all 0.2s; }
    .detail-header .close-btn:hover { background: var(--g-50); color: var(--text-900); }

    .detail-section { margin-bottom: 16px; }
    .detail-section:last-child { margin-bottom: 0; }
    .detail-section-title { font-size: 13px; font-weight: 700; color: var(--brand-600, #0066cc); margin-bottom: 6px; display: flex; align-items: center; gap: 6px; }
    .detail-section-title::before { content: ''; width: 3px; height: 13px; border-radius: 2px; background: var(--brand-500, #0066cc); }
    .detail-section-content { font-size: 14px; line-height: 1.8; color: var(--text-sec); }
    .detail-section-content ul { margin: 4px 0; padding-left: 20px; }
    .detail-section-content li { margin-bottom: 3px; }

    .fmt-elements { display: flex; gap: 6px; flex-wrap: wrap; }
    .fmt-el { font-size: 12px; padding: 2px 9px; border-radius: 8px; background: var(--brand-50, #e6f0ff); color: var(--brand-600, #0066cc); border: 1px solid var(--brand-100, #b8d4ff); }

    .format-demo {
      background: #faf9f6; border: 1px dashed var(--border-light);
      border-radius: 10px; padding: 14px 18px;
      font-size: 13px; line-height: 1.9; color: var(--text-sec);
      white-space: pre-wrap; font-family: "SimSun", "宋体", serif;
    }
    .format-demo .bold { font-weight: 700; color: var(--brand-700, #004499); }
  </style>
</head>
<body>

<div class="navbar">
  <a href="/history-category-complex" class="logo"><img src="/image.png" alt="">粉笔助手</a>
  <a href="/history-category-complex">练习记录</a>
  <a href="/history">列表视图</a>
  <a href="/wrong-questions">错题本</a>
  <a href="/word-frequency">词语统计</a>
  <a href="/quiz">本地题库</a>
  <a href="/shenlun-format" class="active">公文格式</a>
  <a href="/setup" style="margin-left:auto;">切换账号</a>
</div>

<div class="page-wrap" style="max-width:1100px; margin:0 auto; padding:32px 24px 60px;">
  <div class="page-hero">
    <div class="hero-title">申论公文格式</div>
    <div class="hero-sub">国考申论常见公文文种格式速查 · 法定公文 / 事务文书 / 应用文</div>
  </div>

  <!-- 统计栏 -->
  <div class="stats-bar">
    <div class="stats-bar-item">文种总数 <b id="total-count">0</b></div>
    <div class="stats-bar-item">分类数量 <b>3</b></div>
  </div>

  <!-- 分类页 -->
  <div class="category-page" id="categoryPage">
    <div class="format-guide">
      <b>格式要素：</b>标题（首行居中，不加《》）、主送机关/称谓（顶格，后加冒号）、正文（首行空两格，分开头-主体-结尾）、落款（发文机关 + 日期，右下角）。
      <span class="tag tag-full">完整格式</span>标题+称谓+正文+落款
      <span class="tag tag-partial">不完整格式</span>视文种省略称谓或落款
      <span class="tag tag-special">特殊格式</span>如简报报头报尾、编者按等
    </div>
    <div class="cat-grid" id="catGrid"></div>
  </div>

  <!-- 文种列表页 -->
  <div class="doc-list-page" id="docListPage">
    <button class="back-btn" onclick="showCategory()">&#x2190; 返回分类</button>
    <div class="list-title" id="docListTitle"></div>
    <div class="doc-grid" id="docGrid"></div>
  </div>
</div>

<!-- 详情面板 -->
<div class="detail-panel" id="detailPanel" onclick="if(event.target===this)closeDetail()">
  <div class="detail-panel-inner" id="detailInner"></div>
</div>

<script>
var DATA = {
  '法定公文': [
    { name:'命令（令）', fmt:'special', scope:'依照有关法律公布行政法规和规章，宣布施行重大强制性行政措施，嘉奖有关单位及人员。', elements:['标题','正文','落款'], framework:'原由 → 内容 → 要求；原因目的 → 规定或措施 → 希望或要求。', structure:['标题：发文机关 + 文种（如《中华人民共和国主席令》）','正文：颁布缘由 → 命令事项 → 执行要求','落款：签发人 + 日期'], demo:'【标题居中】\n中华人民共和国主席令\n第×号\n\n【正文】\n  《××法》已由××会议通过，现予公布，自×年×月×日起施行。\n\n【落款】\n            中华人民共和国主席 ××\n           2026年×月×日' },
    { name:'决定', fmt:'partial', scope:'对重要事项或重大行动做出安排，奖惩有关单位及人员，变更或撤销下级机关不适当的决定事项。', elements:['标题','正文','落款'], framework:'是什么 → 为什么 → 怎么办；背景和目的 → 重要性和必要性 → 工作举措。', structure:['标题：发文机关 + 事由 + "决定"','正文：决定缘由 → 决定内容（分条列述）→ 执行要求','落款：发文机关 + 日期（主送机关可省略）'], demo:'【标题居中】\n××关于××的决定\n\n【正文】\n  为了××，经××研究，决定如下：\n  一、……\n  二、……\n  三、……\n  各地区各部门要认真贯彻执行。\n\n【落款】\n            ××\n           2026年×月×日' },
    { name:'公告', fmt:'partial', scope:'向国内外宣布重要事项或法定事项。面向全社会，无须写收文机关称谓。', elements:['标题','正文','落款'], framework:'是什么 → 为什么 → 怎么办；背景 → 目的或意义 → 内容 → 号召。', structure:['标题：发文机关 + 事由 + "公告"','正文：公告缘由 → 公告事项 → 结束语（"特此公告"）','落款：发文机关 + 日期','注意：无主送机关（面向全社会）'], demo:'【标题居中】\n××关于××的公告\n\n【正文】\n  根据××，现将××公告如下：\n  一、……\n  二、……\n  特此公告。\n\n【落款】\n            ××\n           2026年×月×日' },
    { name:'通告', fmt:'partial', scope:'公布各有关方面应当遵守或周知的事项。范围小于公告，一般也无须写通告对象称谓。', elements:['标题','正文','落款'], framework:'为什么 → 怎么办；目的 → 要求；事由 → 措施。', structure:['标题：发文机关 + 事由 + "通告"','正文：通告缘由 → 通告事项 → 执行要求 → 结束语（"特此通告"）','落款：发文机关 + 日期','注意：无主送机关'], demo:'【标题居中】\n××关于××的通告\n\n【正文】\n  为做好××工作，维护××，现将有关事项通告如下：\n  一、……\n  二、……\n  特此通告，望周知。\n\n【落款】\n            ××\n           2026年×月×日' },
    { name:'通知', fmt:'full', scope:'发布传达要求下级执行和有关单位周知或执行的事项，批转、转发公文。申论高频考查文种。', elements:['标题','主送机关','正文','落款'], framework:'告知对象 → 告知事项 → 原因理由 → 落实要求。', structure:['标题：发文机关 + 事由 + "通知"（如《关于××的通知》）','主送机关：顶格书写，全称或规范简称，后加冒号','正文：通知缘由 → 通知事项 → 执行要求','落款：发文机关 + 日期'], demo:'【标题居中】\n××关于××的通知\n\n【主送机关顶格】\n各县（市、区）人民政府：\n\n【正文】\n  为了××，现将××有关事项通知如下：\n  一、……\n  二、……\n  请认真贯彻执行。\n\n【落款】\n            ××\n           2026年×月×日' },
    { name:'通报', fmt:'full', scope:'表彰先进、批评错误、传达重要精神或情况。分表彰性、批评性、情况通报三种。', elements:['标题','主送机关','正文','落款'], framework:'事情原由 → 处理情况 → 经验教训总结 → 落实或预防要求。', structure:['标题：发文机关 + 事由 + "通报"','主送机关：顶格书写','正文：事由（叙述事实）→ 分析评价 → 决定（表彰/处分）→ 希望/要求','落款：发文机关 + 日期'], demo:'【标题居中】\n××关于××的通报\n\n【主送机关】\n各部门：\n\n【正文】\n  经查，××（叙述事实）。\n  这一行为××（分析评价）。为××，决定××。\n  希望广大××引以为戒/学习先进，××。\n\n【落款】\n            ××\n           2026年×月×日' },
    { name:'报告', fmt:'full', scope:'向上级机关汇报工作、反映情况、回复询问。申论高频考查文种，分工作报告和情况报告。', elements:['标题','主送机关','正文','落款'], framework:'陈述基本情况 → 指出存在的问题 → 提出解决对策；背景与内涵 → 重要性与必要性 → 重要举措。', structure:['标题：发文机关 + 事由 + "报告"','主送机关：顶格书写（上级机关）','正文：报告缘由 → 报告内容 → 结束语（"特此报告"）','落款：发文机关 + 日期','注意：报告中不得夹带请示事项'], demo:'【标题居中】\n××关于××的报告\n\n【主送机关】\n××人民政府：\n\n【正文】\n  根据××要求，现将××情况报告如下：\n  一、基本情况\n  ……\n  二、主要做法\n  ……\n  三、下一步打算\n  ……\n  特此报告。\n\n【落款】\n            ××\n           2026年×月×日' },
    { name:'请示', fmt:'full', scope:'向上级机关请求指示、批准。分求示性、求准性、求转性三种。', elements:['标题','主送机关','正文','落款'], framework:'请示理由 → 事项 → 要求；背景 → 目的 → 措施。', structure:['标题：发文机关 + 事由 + "请示"','主送机关：只有一个（上级机关），顶格书写','正文：请示缘由 → 请示事项 → 请示要求（"妥否，请批示"）','落款：发文机关 + 日期','注意：一文一事；不得同时抄送下级机关'], demo:'【标题居中】\n××关于××的请示\n\n【主送机关】\n××人民政府：\n\n【正文】\n  为了××（缘由），拟××（事项）。\n  现将有关情况请示如下：\n  一、……\n  二、……\n  妥否，请批示。\n\n【落款】\n            ××\n           2026年×月×日' },
    { name:'批复', fmt:'full', scope:'答复下级机关请示事项。', elements:['标题','主送机关','正文','落款'], framework:'是什么 → 为什么 → 怎么办；背景理由 → 答复指示 → 工作要求。', structure:['标题：发文机关 + 事由 + "批复"','主送机关：请示的发文机关','正文：引述来文（"你《关于××的请示》收悉"）→ 批复意见 → 结束语（"此复"）','落款：发文机关 + 日期'], demo:'【标题居中】\n××关于××的批复\n\n【主送机关】\n××局：\n\n【正文】\n  你《关于××的请示》（×〔2026〕×号）收悉。经研究，现批复如下：\n  一、同意××。\n  二、……\n  此复。\n\n【落款】\n            ××\n           2026年×月×日' },
