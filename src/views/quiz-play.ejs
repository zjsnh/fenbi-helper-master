<!DOCTYPE html>
<html lang="zh">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= setName %> · 做题 · 错题助手</title>
  <link rel="stylesheet" href="/theme.css">
  <style>
    body { background: var(--paper); }

    /* ── 顶部信息栏 ── */
    .quiz-topbar {
      position: sticky; top: 0; z-index: 50;
      background: var(--card);
      border-bottom: 0.5px solid var(--border-light);
      padding: 12px 24px;
      display: flex; align-items: center; gap: 16px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.03);
    }
    .quiz-topbar .back-link {
      font-size: 13px; color: var(--text-sec);
      text-decoration: none;
      padding: 6px 14px; border-radius: 980px;
      border: 0.5px solid var(--border-light);
      transition: all 0.2s;
    }
    .quiz-topbar .back-link:hover { border-color: var(--g-400); color: var(--g-700); }
    .quiz-topbar .set-info {
      flex: 1; min-width: 0;
    }
    .quiz-topbar .set-info .name {
      font-size: 15px; font-weight: 700; color: #0a1628;
      font-family: var(--font-display);
      overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .quiz-topbar .set-info .source-tag {
      font-size: 11px; padding: 2px 8px; border-radius: 10px;
      margin-left: 6px;
    }
    .tag-fr { background: var(--brand-50, #e6f0ff); color: var(--brand-600, #0066cc); border: 1px solid var(--brand-100, #b8d4ff); }
    .tag-lr { background: #fff5e6; color: #b8860b; border: 1px solid #ffdbb0; }
    .quiz-topbar .timer {
      font-size: 18px; font-weight: 700;
      font-family: var(--font-mono);
      color: var(--g-700);
      background: var(--g-50);
      padding: 6px 14px; border-radius: 10px;
      letter-spacing: 1px;
    }

    /* ── 进度条 ── */
    .progress-wrap {
      max-width: 800px; margin: 20px auto 0;
      padding: 0 24px;
    }
    .progress-bar {
      height: 6px; background: var(--g-100);
      border-radius: 4px; overflow: hidden;
    }
    .progress-fill {
      height: 100%; background: linear-gradient(90deg, var(--g-400), var(--g-600));
      border-radius: 4px;
      transition: width 0.35s var(--ease-out);
    }
    .progress-text {
      display: flex; justify-content: space-between;
      font-size: 12px; color: var(--text-ter);
      margin-top: 6px;
    }
    .progress-text .flag-count {
      color: #b8860b; font-weight: 600;
    }

    /* ── 题目主体 ── */
    .quiz-body {
      max-width: 800px; margin: 24px auto 100px;
      padding: 0 24px;
    }
    .question-card {
      background: var(--card);
      border: 0.5px solid var(--border-light);
      border-radius: 14px;
      padding: 28px 32px;
    }
    /* 切换动画：进入 */
    .question-card.enter-next {
      animation: enterNext 0.6s var(--ease-out);
    }
    .question-card.enter-prev {
      animation: enterPrev 0.6s var(--ease-out);
    }
    @keyframes enterNext {
      from { opacity: 0; transform: translateX(40px); }
      to   { opacity: 1; transform: translateX(0); }
    }
    @keyframes enterPrev {
      from { opacity: 0; transform: translateX(-40px); }
      to   { opacity: 1; transform: translateX(0); }
    }
    .q-header {
      display: flex; align-items: center; gap: 10px;
      margin-bottom: 14px;
      font-size: 13px; color: var(--text-ter);
    }
    .q-no {
      font-size: 14px; font-weight: 700; color: var(--g-700);
      background: var(--g-50);
      padding: 4px 12px; border-radius: 8px;
    }
    .q-type {
      font-size: 11px; padding: 2px 8px; border-radius: 8px;
      background: var(--brand-50, #e6f0ff); color: var(--brand-600, #0066cc);
    }
    .q-flag-btn {
      margin-left: auto;
      font-size: 12px; padding: 5px 12px;
      border-radius: 8px;
      border: 0.5px solid var(--border-light);
      background: var(--card); color: var(--text-sec);
      cursor: pointer;
      transition: all 0.2s;
      font-family: inherit;
    }
    .q-flag-btn:hover { border-color: #ffdbb0; }
    .q-flag-btn.flagged {
      background: #fff5e6; color: #b8860b;
      border-color: #ffdbb0;
    }
    .q-flag-btn.flagged::before { content: '★ '; }

    .q-stem {
      font-size: 15px; line-height: 1.85;
      color: var(--text-900);
      margin-bottom: 20px;
      word-break: break-word;
    }
    .q-stem img { max-width: 100%; border-radius: 8px; margin: 8px 0; }
    .q-stem p { margin: 8px 0; }
    .q-image {
      max-width: 100%;
      margin: 10px 0 20px;
      border-radius: 8px;
      border: 0.5px solid var(--border-light);
    }

    .q-options {
      display: flex; flex-direction: column;
      gap: 10px;
    }
    .opt-item {
      display: flex; align-items: flex-start; gap: 12px;
      padding: 12px 16px;
      background: var(--paper-warm, #faf9f6);
      border: 1px solid var(--border-light);
      border-radius: 10px;
      cursor: pointer;
      transition: all 0.2s var(--ease-out);
    }
    .opt-item:hover {
      border-color: var(--g-300);
      background: var(--g-50);
    }
    .opt-item.selected {
      border-color: var(--brand-500, #0066cc);
      background: var(--brand-50, #e6f0ff);
    }
    .opt-letter {
      font-size: 14px; font-weight: 700;
      color: var(--g-700);
      background: var(--card);
      border: 1px solid var(--border-light);
      width: 28px; height: 28px;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
      transition: all 0.2s;
    }
    .opt-item.selected .opt-letter {
      background: var(--brand-600, #0066cc);
      color: #fff;
      border-color: var(--brand-600, #0066cc);
    }
    .opt-text {
      flex: 1;
      font-size: 14px; line-height: 1.7;
      color: var(--text-900);
      padding-top: 4px;
    }

    /* ── 底部操作栏 ── */
    .quiz-footer {
      position: fixed; bottom: 0; left: 0; right: 0;
      background: var(--card);
      border-top: 0.5px solid var(--border-light);
      padding: 14px 24px;
      display: flex; justify-content: center; align-items: center; gap: 12px;
      box-shadow: 0 -2px 12px rgba(0,0,0,0.04);
      z-index: 50;
    }
    .quiz-footer .inner {
      max-width: 800px; width: 100%;
      display: flex; gap: 12px; align-items: center;
    }
    .nav-btn {
      flex: 0 0 auto;
      padding: 10px 22px;
      border-radius: 10px;
      border: 0.5px solid var(--border-light);
      background: var(--card); color: var(--text-sec);
      font-size: 14px; font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
      font-family: inherit;
    }
    .nav-btn:hover:not(:disabled) {
      border-color: var(--g-400); color: var(--g-700);
    }
    .nav-btn:disabled {
      opacity: 0.4; cursor: not-allowed;
    }
    .nav-btn.primary {
      background: var(--brand-600, #0066cc);
      color: #fff;
      border-color: var(--brand-600, #0066cc);
      margin-left: auto;
    }
    .nav-btn.primary:hover:not(:disabled) {
      background: var(--brand-700, #0052a3);
    }
    .nav-btn.danger {
      background: #c0392b; color: #fff; border-color: #c0392b;
    }

    .pos-dots {
      flex: 1;
      display: flex; gap: 6px; flex-wrap: wrap;
      justify-content: center;
    }
    .pos-dot {
      width: 10px; height: 10px; border-radius: 50%;
      background: var(--g-100);
      cursor: pointer;
      transition: all 0.2s;
      border: 1px solid transparent;
    }
    .pos-dot.answered { background: var(--g-500); }
    .pos-dot.flagged { background: #f39c12; }
    .pos-dot.current {
      border-color: var(--brand-600, #0066cc);
      transform: scale(1.3);
    }

    /* ── 提交确认弹层 ── */
    .submit-overlay {
      display: none;
      position: fixed; top: 0; left: 0; right: 0; bottom: 0;
      background: rgba(0,0,0,0.4);
      z-index: 100;
      align-items: center; justify-content: center;
    }
    .submit-overlay.show { display: flex; }
    .submit-dialog {
      background: var(--card);
      border-radius: 16px;
      padding: 28px 32px;
      max-width: 380px; width: 90%;
      box-shadow: 0 12px 40px rgba(0,0,0,0.15);
      animation: panelPop 0.35s var(--ease-spring);
    }
    @keyframes panelPop { from { opacity: 0; transform: scale(0.95); } to { opacity: 1; transform: scale(1); } }
    .submit-dialog h3 {
      margin: 0 0 14px; font-size: 18px; font-weight: 700;
    }
    .submit-dialog .stats {
      display: flex; gap: 14px; margin-bottom: 20px;
    }
    .submit-dialog .stat {
      flex: 1; text-align: center;
      background: var(--g-50); border-radius: 10px;
      padding: 12px 6px;
    }
    .submit-dialog .stat b {
      display: block; font-size: 22px; color: var(--g-700);
      font-family: var(--font-mono);
    }
    .submit-dialog .stat span {
      font-size: 11px; color: var(--text-ter);
    }
    .submit-dialog .actions {
      display: flex; gap: 10px;
    }
    .submit-dialog .actions button {
      flex: 1; padding: 10px;
      border-radius: 10px; border: 0.5px solid var(--border-light);
      background: var(--card); font-size: 14px; cursor: pointer;
      font-family: inherit;
    }
    .submit-dialog .actions .confirm {
      background: var(--brand-600, #0066cc); color: #fff;
      border-color: var(--brand-600, #0066cc);
    }
    /* ── 无选项题（填空/解答）答案展示区 ── */
    .q-no-opt-area {
      margin-top: 24px;
      padding-top: 20px;
      border-top: 0.5px dashed var(--border-light);
    }
    .q-show-answer-btn {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 10px 22px;
      border-radius: 10px;
      border: 0.5px solid var(--brand-500, #0066cc);
      background: var(--brand-50, #e6f0ff);
      color: var(--brand-600, #0066cc);
      font-size: 14px; font-weight: 600;
      cursor: pointer;
      transition: all 0.2s var(--ease-out);
      font-family: inherit;
    }
    .q-show-answer-btn:hover {
      background: var(--brand-100, #b8d4ff);
      border-color: var(--brand-600, #0066cc);
    }
    .q-show-answer-btn.active {
      background: var(--brand-600, #0066cc);
      color: #fff;
      border-color: var(--brand-600, #0066cc);
    }
    .q-show-answer-btn::before {
      content: '▸ ';
      font-size: 12px;
      transition: transform 0.2s;
    }
    .q-show-answer-btn.active::before {
      transform: rotate(90deg);
    }
    .q-answer-panel {
      margin-top: 14px;
      background: var(--paper-warm, #faf9f6);
      border: 0.5px solid var(--border-light);
      border-radius: 12px;
      padding: 18px 22px;
      animation: panelSlide 0.3s var(--ease-out);
    }
    @keyframes panelSlide {
      from { opacity: 0; transform: translateY(-6px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .q-answer-block, .q-analysis-block {
      padding: 10px 0;
    }
    .q-answer-block + .q-analysis-block {
      border-top: 0.5px dashed var(--border-light);
      margin-top: 6px;
    }
    .qa-title {
      font-size: 12px; font-weight: 700;
      color: var(--text-ter);
      letter-spacing: 1px;
      margin-bottom: 6px;
    }
    .q-answer-block .qa-title { color: var(--brand-600, #0066cc); }
    .q-analysis-block .qa-title { color: #b8860b; }
    .qa-content {
      font-size: 14px; line-height: 1.8;
      color: var(--text-900);
      word-break: break-word;
    }
    .qa-content p { margin: 6px 0; }
    .qa-content img { max-width: 100%; border-radius: 6px; margin: 6px 0; }
    /* 无选项题导航点：独立样式（淡紫色，区别于已答灰） */
    .pos-dot.no-opt { background: #e8e3ff; border-color: #c7b8ff; }
    .pos-dot.no-opt.current { border-color: #7a5aff; }

    /* KaTeX 公式样式：行内不溢出，块级居中 */
    .q-stem .katex, .opt-text .katex, .qa-content .katex { font-size: 1.05em; }
    .katex-display { margin: 8px 0; overflow-x: auto; overflow-y: hidden; }
  </style>
  <link rel="stylesheet" href="/js/katex/katex.min.css">
</head>
<body>

<div class="quiz-topbar">
  <a class="back-link" href="/quiz">← 题库</a>
  <div class="set-info">
    <span class="name"><%= setName %>
      <span class="source-tag <%= setId.indexOf('lr_') === 0 ? 'tag-lr' : 'tag-fr' %>"><%= setId.indexOf('lr_') === 0 ? '逻辑' : '阅读' %></span>
    </span>
  </div>
  <div class="timer" id="timer">00:00</div>
</div>

<div class="progress-wrap">
  <div class="progress-bar"><div class="progress-fill" id="progressFill" style="width:0%"></div></div>
  <div class="progress-text">
    <span>第 <b id="curNo">1</b> / <%= questions.length %> 题</span>
    <span>已答 <b id="answeredCount">0</b> · 疑题 <b class="flag-count" id="flaggedCount">0</b></span>
  </div>
</div>

<div class="quiz-body">
  <div class="question-card" id="qCard"></div>
</div>

<div class="quiz-footer">
  <div class="inner">
    <button class="nav-btn" id="prevBtn" onclick="goPrev()">← 上一题</button>
    <div class="pos-dots" id="posDots"></div>
    <button class="nav-btn primary" id="nextBtn" onclick="goNext()">下一题 →</button>
    <button class="nav-btn danger" id="submitBtn" style="display:none" onclick="openSubmitDialog()">提交</button>
  </div>
</div>

<div class="submit-overlay" id="submitOverlay">
  <div class="submit-dialog">
    <h3>确认提交？</h3>
    <div class="stats">
      <div class="stat"><b id="dlgAnswered">0</b><span>已答</span></div>
      <div class="stat"><b id="dlgUnanswered">0</b><span>未答</span></div>
      <div class="stat"><b id="dlgFlagged">0</b><span>疑题</span></div>
    </div>
    <div class="actions">
      <button onclick="closeSubmitDialog()">再检查下</button>
      <button class="confirm" id="confirmSubmitBtn" onclick="doSubmit()">确认提交</button>
    </div>
  </div>
</div>

<script>
// 题目数据
var QUESTIONS = <%- JSON.stringify(questions) %>;
var SET_ID = '<%= setId %>';
var SET_NAME = <%- JSON.stringify(setName) %>;
var SET_SOURCE = <%- JSON.stringify(source || '') %>;
var START_TS = Date.now();

// 图片URL转换：相对路径(如 images/xxx.jpg) => /quiz-img/{source}/images/xxx.jpg
// 绝对URL(http/https) 原样返回；多图用 | 分隔
function resolveImgUrl(url) {
  if (!url) return '';
  // 多图分隔
  return url;
}
function buildImgSrc(rel) {
  rel = String(rel || '').trim();
  if (!rel) return '';
  if (/^https?:\/\//i.test(rel)) return rel;       // 绝对 URL
  if (rel.charAt(0) === '/') return rel;            // 已是根路径
  // 相对路径：images/xxx.jpg => /quiz-img/{source}/images/xxx.jpg
  return '/quiz-img/' + encodeURIComponent(SET_SOURCE) + '/' + rel.replace(/^\/+/, '');
}

// 状态
var curIdx = 0;
var answers = {};      // qNo -> 'A'/'B'/...
var flagged = {};      // qNo -> true

// ── 计时器 ──
function pad(n) { return n < 10 ? '0' + n : '' + n; }
function updateTimer() {
  var s = Math.floor((Date.now() - START_TS) / 1000);
  var m = Math.floor(s / 60);
  s = s % 60;
  document.getElementById('timer').textContent = pad(m) + ':' + pad(s);
}
setInterval(updateTimer, 1000);

// ── 渲染当前题 ──
// dir: 'next' | 'prev' | undefined（仅控制进入动画方向）
function renderQuestion(dir) {
  var q = QUESTIONS[curIdx];
  if (!q) return;

  var isNoOpt = !q.options || q.options.length === 0; // 无选项题（填空/解答）

  var html = '<div class="q-header">';
  html += '<span class="q-no">第 ' + (curIdx + 1) + ' 题</span>';
  html += '<span class="q-type">' + (q.type || '单选') + '</span>';
  // 无选项题不显示标记疑题按钮
  if (!isNoOpt) {
    html += '<button class="q-flag-btn' + (flagged[q.qNo] ? ' flagged' : '') + '" onclick="toggleFlag(' + q.qNo + ')">';
    html += flagged[q.qNo] ? '已标记疑题' : '标记疑题';
    html += '</button>';
  }
  html += '</div>';

  html += '<div class="q-stem">' + q.stem + '</div>';

  if (q.imageUrl) {
    // 图片URL支持多图（| 分隔），相对路径自动转换
    var imgs = String(q.imageUrl).split('|').map(function(s){ return s.trim(); }).filter(Boolean);
    imgs.forEach(function(src) {
      var realSrc = buildImgSrc(src);
      html += '<img class="q-image" src="' + escapeAttr(realSrc) + '" alt="题目图片" onerror="this.style.display=\'none\'">';
    });
  }

  if (isNoOpt) {
    // 无选项题：渲染「显示答案」按钮，点击展开答案+解析
    html += '<div class="q-no-opt-area">';
    html += '<button class="q-show-answer-btn" onclick="toggleAnswer(' + q.qNo + ')" id="ansBtn_' + q.qNo + '">显示答案</button>';
    html += '<div class="q-answer-panel" id="ansPanel_' + q.qNo + '" style="display:none;">';
    html += '<div class="q-answer-block"><div class="qa-title">答案</div><div class="qa-content">' + (q.answer || '') + '</div></div>';
    if (q.analysis) {
      html += '<div class="q-analysis-block"><div class="qa-title">解析</div><div class="qa-content">' + q.analysis + '</div></div>';
    }
    html += '</div>';
    html += '</div>';
  } else {
    html += '<div class="q-options">';
    var letters = ['A','B','C','D','E','F'];
    var isMulti = /多(选|项)/.test(String(q.type));
    // 当前已选字母（多选存数组，单选存字符串）
    var curAns = answers[q.qNo];
    for (var i = 0; i < q.options.length; i++) {
      var L = letters[i];
      var sel = '';
      if (isMulti) {
        if (curAns && curAns.indexOf(L) >= 0) sel = ' selected';
      } else {
        if (curAns === L) sel = ' selected';
      }
      html += '<div class="opt-item' + sel + '" onclick="choose(\'' + L + '\')">';
      html += '<div class="opt-letter">' + L + '</div>';
      html += '<div class="opt-text">' + escapeHtml(q.options[i]) + '</div>';
      html += '</div>';
    }
    html += '</div>';

    // 多选题提示
    if (isMulti) {
      html += '<div style="margin-top:12px;font-size:12px;color:var(--text-ter);">多选题：可选择多个选项，选完点击「下一题」继续</div>';
    }
  }

  var card = document.getElementById('qCard');
  card.innerHTML = html;

  // 渲染题干与选项中的 LaTeX 公式（KaTeX auto-render）
  if (typeof renderMathInElement === 'function') {
    renderMathInElement(card, KATEX_OPTS);
  }

  // 重新触发进入动画（带方向）
  card.classList.remove('enter-next', 'enter-prev');
  // 强制 reflow 让动画重新触发
  void card.offsetWidth;
  if (dir === 'prev') {
    card.classList.add('enter-prev');
  } else if (dir === 'next') {
    card.classList.add('enter-next');
  }

  // 更新进度
  document.getElementById('curNo').textContent = curIdx + 1;
  document.getElementById('progressFill').style.width = ((curIdx + 1) / QUESTIONS.length * 100) + '%';
  updateStatus();
  updateNav();
  renderDots();
}

function escapeHtml(s) {
  if (s == null) return '';
  return String(s).replace(/[&<>"']/g, function(c) {
    return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c];
  });
}
function escapeAttr(s) {
  return escapeHtml(s);
}

function choose(letter) {
  var q = QUESTIONS[curIdx];
  var isMulti = /多(选|项)/.test(String(q.type));

  if (isMulti) {
    // 多选题：切换选中状态，不自动跳转
    var cur = answers[q.qNo] || '';
    if (cur.indexOf(letter) >= 0) {
      // 取消选择
      cur = cur.replace(letter, '');
      if (cur) answers[q.qNo] = cur;
      else delete answers[q.qNo];
    } else {
      // 追加选择
      cur = cur + letter;
      // 排序便于显示一致
      answers[q.qNo] = cur.split('').sort().join('');
    }
    renderQuestion();
  } else {
    // 单选题：保持原逻辑
    if (answers[q.qNo] === letter) {
      delete answers[q.qNo];
      renderQuestion();
    } else {
      answers[q.qNo] = letter;
      renderQuestion();
      // 选择后自动跳转下一题（最后一题不跳）
      if (curIdx < QUESTIONS.length - 1) {
        setTimeout(function() { goNext(); }, 300);
      }
    }
  }
}

function toggleFlag(qNo) {
  if (flagged[qNo]) delete flagged[qNo];
  else flagged[qNo] = true;
  renderQuestion();
}

function goPrev() {
  if (curIdx > 0) { curIdx--; renderQuestion('prev'); }
}

function goNext() {
  if (curIdx < QUESTIONS.length - 1) { curIdx++; renderQuestion('next'); }
  else { openSubmitDialog(); }
}

// 方向键左右切换题目（焦点在输入框/文本域时不触发，避免与输入冲突）
document.addEventListener('keydown', function(e) {
  var tag = (e.target && e.target.tagName) || '';
  if (/^(INPUT|TEXTAREA|SELECT)$/i.test(tag)) return;
  if (e.key === 'ArrowLeft')      { e.preventDefault(); goPrev(); }
  else if (e.key === 'ArrowRight') { e.preventDefault(); goNext(); }
});

function updateNav() {
  document.getElementById('prevBtn').disabled = (curIdx === 0);
  var nextBtn = document.getElementById('nextBtn');
  var submitBtn = document.getElementById('submitBtn');
  if (curIdx === QUESTIONS.length - 1) {
    nextBtn.style.display = 'none';
    submitBtn.style.display = '';
    submitBtn.classList.remove('danger');
    submitBtn.classList.add('primary');
  } else {
    nextBtn.style.display = '';
    submitBtn.style.display = 'none';
  }
}

function updateStatus() {
  // 统计有选项题中已作答数量
  var answered = 0;
  var noOptCount = 0;
  for (var i = 0; i < QUESTIONS.length; i++) {
    var q = QUESTIONS[i];
    if (!q.options || q.options.length === 0) {
      noOptCount++;
    } else if (answers[q.qNo]) {
      answered++;
    }
  }
  var flagCount = Object.keys(flagged).length;
  document.getElementById('answeredCount').textContent = answered;
  document.getElementById('flaggedCount').textContent = flagCount;
}

// 无选项题：切换「显示答案」面板展开/收起
function toggleAnswer(qNo) {
  var panel = document.getElementById('ansPanel_' + qNo);
  var btn = document.getElementById('ansBtn_' + qNo);
  if (!panel || !btn) return;
  if (panel.style.display === 'none') {
    panel.style.display = 'block';
    btn.textContent = '隐藏答案';
    btn.classList.add('active');
    // 展开后渲染面板内的 LaTeX 公式
    if (typeof renderMathInElement === 'function') {
      renderMathInElement(panel, KATEX_OPTS);
    }
  } else {
    panel.style.display = 'none';
    btn.textContent = '显示答案';
    btn.classList.remove('active');
  }
}

function renderDots() {
  var html = '';
  for (var i = 0; i < QUESTIONS.length; i++) {
    var q = QUESTIONS[i];
    var cls = 'pos-dot';
    var isNoOpt = !q.options || q.options.length === 0;
    if (isNoOpt) {
      cls += ' no-opt'; // 无选项题用独立样式
    } else if (answers[q.qNo]) {
      cls += ' answered';
    }
    if (flagged[q.qNo]) cls += ' flagged';
    if (i === curIdx) cls += ' current';
    html += '<div class="' + cls + '" onclick="goTo(' + i + ')"></div>';
  }
  document.getElementById('posDots').innerHTML = html;
}

function goTo(idx) {
  var dir = idx > curIdx ? 'next' : 'prev';
  curIdx = idx;
  renderQuestion(dir);
}

// ── 提交 ──
function openSubmitDialog() {
  // 仅统计有选项题
  var optCount = 0;
  var answered = 0;
  for (var i = 0; i < QUESTIONS.length; i++) {
    var q = QUESTIONS[i];
    if (q.options && q.options.length > 0) {
      optCount++;
      if (answers[q.qNo]) answered++;
    }
  }
  var unanswered = optCount - answered;
  var flagCount = Object.keys(flagged).length;
  document.getElementById('dlgAnswered').textContent = answered;
  document.getElementById('dlgUnanswered').textContent = unanswered;
  document.getElementById('dlgFlagged').textContent = flagCount;
  document.getElementById('submitOverlay').classList.add('show');
}
function closeSubmitDialog() {
  document.getElementById('submitOverlay').classList.remove('show');
}

function doSubmit() {
  document.getElementById('confirmSubmitBtn').disabled = true;
  document.getElementById('confirmSubmitBtn').textContent = '提交中...';

  var payload = {
    setId: SET_ID,
    setName: SET_NAME,
    startTime: START_TS,
    endTime: Date.now(),
    durationMs: Date.now() - START_TS,
    answers: answers,
    flagged: Object.keys(flagged).map(Number)
  };

  fetch('/quiz/' + SET_ID + '/submit', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(payload)
  })
  .then(function(r) {
    if (!r.ok) return r.json().then(function(d) { throw new Error(d.error || '提交失败'); });
    return r.json();
  })
  .then(function(d) {
    window.location = '/quiz-result/' + d.recordId + '?from=/quiz';
  })
  .catch(function(e) {
    alert('提交失败：' + e.message);
    document.getElementById('confirmSubmitBtn').disabled = false;
    document.getElementById('confirmSubmitBtn').textContent = '确认提交';
  });
}

// ── 初始化 ──
renderQuestion();
</script>

<!-- KaTeX：LaTeX 公式渲染 -->
<script src="/js/katex/katex.min.js"></script>
<script src="/js/katex/auto-render.min.js"></script>
<script>
// KaTeX auto-render 全局配置：识别 $...$ 行内、$$...$$ 块级、\(\)、\[]
var KATEX_OPTS = {
  delimiters: [
    {left: '$$', right: '$$', display: true},
    {left: '\\[', right: '\\]', display: true},
    {left: '\\(', right: '\\)', display: false},
    {left: '$', right: '$', display: false}
  ],
  throwOnError: false,
  ignoredTags: ['script', 'noscript', 'style', 'textarea', 'pre', 'code']
};
// KaTeX 异步加载后，对已渲染的首题补渲染一次
if (typeof renderMathInElement === 'function') {
  var card = document.getElementById('qCard');
  if (card) renderMathInElement(card, KATEX_OPTS);
}
</script>
</body>
</html>
