<html lang="zh">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>练习记录 · 错题助手</title>
  <link rel="stylesheet" href="/theme.css">
  <link rel="stylesheet" href="//cdn.jsdelivr.net/cal-heatmap/3.3.10/cal-heatmap.css" />
  <style>
    body { background: var(--paper); }

    /* 热力图容器 */
    #cal-heatmap { margin: 0 0 28px; }

    /* 分类区块 — 折叠手风琴 */
    .cat-section {
      margin-bottom: 20px;
      animation: fadeUp 0.5s var(--ease-decel) both;
    }
    .cat-section:nth-child(2) { animation-delay: 0.08s; }
    .cat-section:nth-child(3) { animation-delay: 0.16s; }
    .cat-section:nth-child(4) { animation-delay: 0.24s; }
    .cat-section:nth-child(5) { animation-delay: 0.32s; }

    .cat-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 14px 20px;
      background: var(--card);
      border: 0.5px solid var(--border-light);
      border-radius: var(--radius);
      cursor: pointer;
      transition: all 0.35s var(--ease);
      box-shadow: var(--shadow-xs);
      position: relative;
      overflow: hidden;
      user-select: none;
    }
    .cat-header::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 3px;
      background: linear-gradient(180deg, var(--g-300), var(--g-500));
      opacity: 0;
      transition: opacity 0.3s var(--ease);
    }
    .cat-header:hover::before { opacity: 1; }
    .cat-header:hover {
      border-color: var(--g-200);
      box-shadow: var(--shadow);
      transform: none;
    }
    .cat-header.open {
      border-radius: var(--radius) var(--radius) 0 0;
      border-color: var(--g-200);
      background: var(--g-50);
    }
    .cat-header.open::before { opacity: 1; }
    .cat-header .cat-name {
      font-size: 15px;
      font-weight: 700;
      font-family: var(--font-display);
      color: var(--g-700);
    }
    .cat-header .cat-meta {
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .cat-header .cnt {
      font-size: 12px;
      font-weight: 600;
      color: var(--g-600);
      background: var(--g-50);
      padding: 3px 12px;
      border-radius: 12px;
      border: 0.5px solid var(--g-200);
    }
    .cat-header .arrow {
      font-size: 10px;
      color: var(--ink-400);
      transition: transform 0.35s var(--ease);
    }
    .cat-header.open .arrow { transform: rotate(180deg); }

    /* 展开内容 */
    .cat-body {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.45s var(--ease);
      border: 1px solid transparent;
      border-top: none;
      border-radius: 0 0 var(--radius) var(--radius);
      background: var(--paper);
    }
    .cat-body.open {
      max-height: 600px;
      overflow-y: auto;
      border-color: var(--border-light);
      scrollbar-width: thin;
      scrollbar-color: var(--g-200) transparent;
    }
    .cat-body.open::-webkit-scrollbar { width: 6px; }
    .cat-body.open::-webkit-scrollbar-track { background: transparent; }
    .cat-body.open::-webkit-scrollbar-thumb {
      background: var(--g-200);
      border-radius: 3px;
    }
    .cat-body-inner { padding: 8px 16px 16px; }

    /* 子分类标题 */
    .sub-cat-title {
      font-size: 13px;
      font-weight: 600;
      color: var(--ink-700);
      margin: 14px 0 8px 12px;
      padding-left: 10px;
      border-left: 2px solid var(--g-300);
      line-height: 1;
    }
    .sub-cat-title-sm {
      font-size: 12px;
      font-weight: 500;
      color: var(--ink-500);
      margin: 10px 0 6px 28px;
      padding-left: 8px;
      border-left: 2px solid var(--ink-300);
      line-height: 1;
    }

    /* 练习记录行 — 墨迹条 */
    .ex-item-list { padding-left: 8px; }
    .ex-row {
      display: flex;
      align-items: center;
      padding: 10px 16px;
      margin: 0 0 4px 0;
      background: var(--card);
      border: 0.5px solid var(--border-light);
      border-radius: var(--radius-sm);
      cursor: pointer;
      transition: all 0.3s var(--ease);
      gap: 12px;
      position: relative;
      overflow: hidden;
    }
    .ex-row::after {
      content: '';
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 2px;
      background: var(--g-400);
      transform: scaleY(0);
      transition: transform 0.3s var(--ease);
    }
    .ex-row:hover::after { transform: scaleY(1); }
    .ex-row:hover {
      box-shadow: var(--shadow-sm);
      border-color: var(--g-200);
      transform: translateX(4px);
    }
    .ex-row.highlight {
      background: var(--g-50);
      border-color: var(--g-300);
    }
    .ex-row.highlight::after { transform: scaleY(1); }
    .ex-row .rate {
      font-size: 18px;
      font-weight: 800;
      font-family: var(--font-display);
      color: var(--g-600);
      flex-shrink: 0;
      min-width: 48px;
      text-align: center;
      letter-spacing: -1px;
    }
    .ex-row .title {
      flex: 1;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      font-size: 13px;
      font-weight: 500;
      color: var(--text);
      min-width: 0;
    }
    .ex-row .meta {
      font-size: 10px;
      font-weight: 600;
      padding: 2px 8px;
      border-radius: 8px;
      background: var(--g-50);
      color: var(--g-600);
      white-space: nowrap;
      border: 0.5px solid var(--g-100);
    }
    .ex-row .date {
      font-size: 11px;
      color: var(--text-ter);
      white-space: nowrap;
      flex-shrink: 0;
    }

    .empty-hint {
      text-align: center;
      padding: 40px 20px;
      color: var(--text-ter);
      font-size: 14px;
    }

    /* 热力图样式覆盖 */
    #cal-heatmap {
      max-height: 280px;
      overflow: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: thin;
      scrollbar-color: var(--g-200) transparent;
    }
    #cal-heatmap::-webkit-scrollbar { width: 6px; height: 6px; }
    #cal-heatmap::-webkit-scrollbar-track { background: transparent; }
    #cal-heatmap::-webkit-scrollbar-thumb {
      background: var(--g-200);
      border-radius: 3px;
    }
    .cal-heatmap-container {
      -webkit-overflow-scrolling: touch;
    }
    .graph-domain { margin-bottom: 4px !important; }

    /* ── 入场动画增强 ── */
    #cal-heatmap {
      animation: fadeUp 0.6s var(--ease-out) both;
    }
    .cat-section {
      animation: fadeUp 0.5s var(--ease-decel) both;
    }
    .cat-section:nth-child(1) { animation-delay: 0.1s; }
    .cat-section:nth-child(2) { animation-delay: 0.18s; }
    .cat-section:nth-child(3) { animation-delay: 0.26s; }
    .cat-section:nth-child(4) { animation-delay: 0.34s; }
    .cat-section:nth-child(5) { animation-delay: 0.42s; }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(12px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes spin {
      from { transform: rotate(0deg); }
      to   { transform: rotate(360deg); }
    }

    /* ── 多选导出工具栏 ── */
    .ex-export-bar {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 10px 14px;
      margin: 4px 0 10px 8px;
      background: var(--g-50);
      border: 0.5px solid var(--g-200);
      border-radius: var(--radius-sm);
      flex-wrap: wrap;
    }
    .ex-export-bar label {
      font-size: 12px;
      font-weight: 600;
      color: var(--g-700);
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 4px;
      user-select: none;
    }
    .ex-export-bar .ex-sel-count {
      font-size: 11px;
      color: var(--ink-500);
    }
    .ex-export-bar .ex-sel-count b {
      color: var(--g-600);
      font-weight: 700;
    }
    .ex-export-bar .ex-exp-btn {
      font-size: 11px;
      font-weight: 600;
      padding: 5px 14px;
      border-radius: 6px;
      border: 0.5px solid var(--g-300);
      background: var(--card);
      color: var(--g-700);
      cursor: pointer;
      transition: all 0.2s;
      font-family: inherit;
    }
    .ex-export-bar .ex-exp-btn:hover {
      background: var(--g-100);
      border-color: var(--g-400);
    }
    .ex-export-bar .ex-exp-btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }
    .ex-export-bar .ex-exp-btn .spinner-sm {
      display: inline-block;
      width: 11px;
      height: 11px;
      border: 1.5px solid rgba(0,0,0,0.2);
      border-top-color: var(--g-600);
      border-radius: 50%;
      animation: spin 0.6s linear infinite;
      vertical-align: middle;
      margin-right: 4px;
    }
    .ex-cb {
      width: 15px;
      height: 15px;
      cursor: pointer;
      accent-color: var(--g-500);
      flex-shrink: 0;
    }
  </style>
  <script src="/d3.min.js"></script>
  <script src="//cdn.jsdelivr.net/cal-heatmap/3.3.10/cal-heatmap.min.js"></script>
</head>
<body>

<div class="navbar">
  <a href="/history-category-complex" class="logo"><img src="/logo.svg" alt="">错题助手</a>
  <a href="/history-category-complex" class="active">练习记录</a>
  <a href="/history">列表视图</a>
  <a href="/wrong-questions">错题本</a>
  <a href="/word-frequency">词语统计</a>
  <a href="/quiz">本地题库</a>
  <a href="/shenlun-format">公文格式</a>
  <a href="/setup" style="margin-left:auto;">切换账号</a>
  <span id="deviceBadge" style="font-size:10px;color:var(--ink-400);padding:3px 8px;border:0.5px solid var(--g-200);border-radius:6px;font-family:var(--font-mono, monospace);" title="当前设备指纹">设备 -</span>
</div>
<script>
  // 由 device.js 写入 window.__DEVICE_ID__，此处兜底展示
  (function () {
    function show() {
      var id = window.__DEVICE_ID__ || (window.getDeviceId && window.getDeviceId());
      if (id) {
        var el = document.getElementById('deviceBadge');
        if (el) el.textContent = '设备 ' + id.slice(0, 8);
      }
    }
    if (window.__DEVICE_ID__) show();
    else document.addEventListener('DOMContentLoaded', function () { setTimeout(show, 100); });
  })();
</script>

<div class="container-wide">
  <% if (exerciseHistory.length == 0) { %><script>window.location='/setup'</script><% } %>

  <!-- 页面头部 -->
  <div class="page-hero" style="display:flex;align-items:center;justify-content:space-between;">
    <div>
      <div class="hero-title">练习记录</div>
      <div class="hero-sub">
        回顾每一次练习，追踪进步轨迹
        <span id="cacheHint" style="font-size:11px;color:var(--ink-400);margin-left:8px;"></span>
      </div>
    </div>
    <div style="display:flex;align-items:center;gap:10px;">
      <span id="cacheTime" style="font-size:11px;color:var(--ink-400);"></span>
      <button id="refreshBtn" onclick="refreshData()" style="
        padding: 8px 20px;
        border: 1px solid var(--g-300);
        border-radius: var(--radius-sm);
        background: var(--card);
        color: var(--g-700);
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        gap: 6px;
      ">
        <svg id="refreshIcon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0 1 18.8-4.3M22 12.5a10 10 0 0 1-18.8 4.3"/></svg>
        刷新数据
      </button>
    </div>
  </div>

  <!-- 热力图 -->
  <div class="card" style="margin-bottom:28px; padding:20px;">
    <div id="cal-heatmap"></div>
  </div>

  <!-- 分类练习记录：手风琴式 -->
  <% for (let c1 of groupItems) { %>
    <% if (c1.count > 0) { %>
    <div class="cat-section">
      <div class="cat-header" onclick="toggleSection(this)">
        <span class="cat-name"><%= c1.type %></span>
        <div class="cat-meta">
          <span class="cnt"><%= c1.count %> 题</span>
          <span class="arrow">&#x25BC;</span>
        </div>
      </div>
      <div class="cat-body">
        <div class="cat-body-inner">
          <!-- 多选导出工具栏 -->
          <div class="ex-export-bar">
            <label><input type="checkbox" class="ex-sel-all-cb" onclick="toggleSelectAll(this)"> 全选</label>
            <span class="ex-sel-count">已选 <b>0</b> 项</span>
            <button class="ex-exp-btn" onclick="exportExercises(this, 'wrong', '<%= c1.type %>')">导出错题PDF</button>
            <button class="ex-exp-btn" onclick="exportExercises(this, 'unanswered', '<%= c1.type %>')">导出未写PDF</button>
          </div>

          <!-- 一级练习项 -->
          <% if (c1.items && c1.items.length > 0) { %>
          <div class="ex-item-list">
            <% for (let item of c1.items) { %>
            <div class="ex-row" id="his-<%= item.id %>" onclick="showReport('<%= item.id %>', <%= !!item._isLocalQuiz %>)">
              <input type="checkbox" class="ex-cb" data-id="<%= item.id %>" onclick="event.stopPropagation()" onchange="updateSelCount(this)">
              <span class="rate"><%= item.correctRate %>%</span>
              <span class="title" title="<%= item.cleanName %>"><%= item.cleanName %><% if (item._isLocalQuiz) { %> <span style="font-size:10px;color:#0066cc;background:#e6f0ff;padding:1px 6px;border-radius:6px;border:1px solid #b8d4ff;margin-left:4px;">本地</span><% } %></span>
              <span class="meta"><%= item.answerCount %>题</span>
              <span class="date"><%= item.finishedDate %></span>
            </div>
            <% } %>
          </div>
          <% } %>

          <!-- 二级子分类 -->
          <% for (let c2 of c1.childTypes) { %>
            <% if (c2.count > 0) { %>
            <div class="sub-cat-title"><%= c2.type %></div>
              <% if (c2.items && c2.items.length > 0) { %>
              <div class="ex-item-list">
                <% for (let item of c2.items) { %>
                <div class="ex-row" id="his-<%= item.id %>" onclick="showReport('<%= item.id %>', <%= !!item._isLocalQuiz %>)">
                  <input type="checkbox" class="ex-cb" data-id="<%= item.id %>" onclick="event.stopPropagation()" onchange="updateSelCount(this)">
                  <span class="rate"><%= item.correctRate %>%</span>
                  <span class="title" title="<%= item.cleanName %>"><%= item.cleanName %><% if (item._isLocalQuiz) { %> <span style="font-size:10px;color:#0066cc;background:#e6f0ff;padding:1px 6px;border-radius:6px;border:1px solid #b8d4ff;margin-left:4px;">本地</span><% } %></span>
                  <span class="meta"><%= item.answerCount %>题</span>
                  <span class="date"><%= item.finishedDate %></span>
                </div>
                <% } %>
              </div>
              <% } %>

              <!-- 三级子分类 -->
              <% for (let c3 of c2.childTypes) { %>
                <% if (c3.count > 0) { %>
                <div class="sub-cat-title-sm"><%= c3.type %></div>
                  <% if (c3.items && c3.items.length > 0) { %>
                  <div class="ex-item-list">
                    <% for (let item of c3.items) { %>
                    <div class="ex-row" id="his-<%= item.id %>" onclick="showReport('<%= item.id %>', <%= !!item._isLocalQuiz %>)">
                      <input type="checkbox" class="ex-cb" data-id="<%= item.id %>" onclick="event.stopPropagation()" onchange="updateSelCount(this)">
                      <span class="rate"><%= item.correctRate %>%</span>
                      <span class="title" title="<%= item.cleanName %>"><%= item.cleanName %><% if (item._isLocalQuiz) { %> <span style="font-size:10px;color:#0066cc;background:#e6f0ff;padding:1px 6px;border-radius:6px;border:1px solid #b8d4ff;margin-left:4px;">本地</span><% } %></span>
                      <span class="meta"><%= item.answerCount %>题</span>
                      <span class="date"><%= item.finishedDate %></span>
                    </div>
                    <% } %>
                  </div>
                  <% } %>
                <% } %>
              <% } %>
            <% } %>
          <% } %>
        </div>
      </div>
    </div>
    <% } %>
  <% } %>

  <% if (groupItems.every(function(c){ return c.count === 0; })) { %>
    <div class="empty-hint">暂无练习记录</div>
  <% } %>
</div>

<script>
  /* 显示缓存状态 */
  (function() {
    var fromCache = <%= typeof _fromCache !== 'undefined' ? _fromCache : 'false' %>;
    var cachedAt = <%= typeof _cachedAt !== 'undefined' && _cachedAt ? _cachedAt : '0' %>;
    var cacheTimeEl = document.getElementById('cacheTime');
    var cacheHintEl = document.getElementById('cacheHint');
    if (fromCache && cachedAt) {
      var d = new Date(cachedAt);
      var timeStr = d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0') + '-' + String(d.getDate()).padStart(2,'0') + ' ' + String(d.getHours()).padStart(2,'0') + ':' + String(d.getMinutes()).padStart(2,'0');
      cacheHintEl.textContent = '(本地缓存)';
      cacheTimeEl.textContent = '更新于 ' + timeStr;
    } else if (fromCache) {
      cacheHintEl.textContent = '(本地缓存)';
    } else {
      cacheHintEl.textContent = '(最新数据)';
    }
  })();

  /* 刷新数据：强制从API重新获取 */
  function refreshData() {
    var btn = document.getElementById('refreshBtn');
    var icon = document.getElementById('refreshIcon');
    btn.disabled = true;
    btn.style.opacity = '0.6';
    btn.style.cursor = 'wait';
    icon.style.animation = 'spin 0.8s linear infinite';
    window.location.href = '/history-category-complex?refresh=1';
  }

// ── Scroll entrance animations ──
(function(){
  var els = document.querySelectorAll('.anim-in');
  if(!els.length) return;
  var io = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if(e.isIntersecting){ e.target.classList.add('visible'); io.unobserve(e.target); }
    });
  }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
  els.forEach(function(el){ io.observe(el); });
})();

  /* 手风琴切换 */
  function toggleSection(header) {
    var body = header.nextElementSibling;
    var isOpen = header.classList.contains('open');
    if (isOpen) {
      header.classList.remove('open');
      body.classList.remove('open');
    } else {
      header.classList.add('open');
      body.classList.add('open');
    }
  }

  function showReport(id, isLocalQuiz) {
    if (isLocalQuiz) {
      window.open('/quiz-result/' + id + '?from=/history-category-complex', '_blank');
    } else {
      window.open('/exercise/' + id + '?from=/history-category-complex', '_blank');
    }
  }

  /* ── 多选导出 ── */
  // 全选/取消全选（作用域：当前 cat-section）
  function toggleSelectAll(cb) {
    var section = cb.closest('.cat-section');
    var cbs = section.querySelectorAll('.ex-cb');
    cbs.forEach(function(c) { c.checked = cb.checked; });
    updateSectionCount(section);
  }

  // 单个复选框变化时更新计数
  function updateSelCount(cb) {
    var section = cb.closest('.cat-section');
    updateSectionCount(section);
  }

  function updateSectionCount(section) {
    var cbs = section.querySelectorAll('.ex-cb');
    var checked = section.querySelectorAll('.ex-cb:checked');
    var countEl = section.querySelector('.ex-sel-count b');
    if (countEl) countEl.textContent = checked.length;
    // 更新全选框状态
    var selAllCb = section.querySelector('.ex-sel-all-cb');
    if (selAllCb) {
      selAllCb.checked = cbs.length > 0 && checked.length === cbs.length;
      selAllCb.indeterminate = checked.length > 0 && checked.length < cbs.length;
    }
  }

  // 导出错题/未写题目 PDF
  function exportExercises(btn, type, moduleName) {
    var section = btn.closest('.cat-section');
    var checked = section.querySelectorAll('.ex-cb:checked');
    if (checked.length === 0) {
      alert('请先勾选要导出的练习记录');
      return;
    }
    var ids = Array.prototype.map.call(checked, function(c) {
      return parseInt(c.getAttribute('data-id'));
    });

    // 禁用按钮，显示加载状态
    var bar = section.querySelector('.ex-export-bar');
    var btns = bar.querySelectorAll('.ex-exp-btn');
    btns.forEach(function(b) { b.disabled = true; });
    var origText = btn.textContent;
    btn.innerHTML = '<span class="spinner-sm"></span>生成中...';

    fetch('/api/exercises/export-pdf', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ exerciseIds: ids, type: type, moduleName: moduleName })
    })
    .then(function(r) {
      if (!r.ok) return r.json().then(function(d) { throw new Error(d.error || '导出失败'); });
      return r.blob();
    })
    .then(function(blob) {
      var url = URL.createObjectURL(blob);
      var a = document.createElement('a');
      a.href = url;
      a.download = moduleName + (type === 'wrong' ? '-错题' : '-未写') + '.pdf';
      document.body.appendChild(a);
      a.click();
      a.remove();
      URL.revokeObjectURL(url);
    })
    .catch(function(e) {
      alert('导出失败：' + e.message);
    })
    .finally(function() {
      btns.forEach(function(b) { b.disabled = false; });
      btn.innerHTML = origText;
    });
  }

  // 热力图
  <% if (exerciseHistory.length > 0) { %>
  var cal = new CalHeatMap();
  cal.init({
    domain: 'month', subDomain: 'day', domainGutter: 6,
    tooltip: true, range: 12,
    start: new Date('<%= moment().startOf("month").startOf("day").subtract(1,"year").add(1,"month").format("YYYY-MM-DD") %>'),
    data: <%- JSON.stringify(exerciseHeatMapData) %>,
    domainLabelFormat: '%m月', displayLegend: false,
    cellSize: 12,
    legend: [15, 35, 70, 100],
    onClick: function(date) {
      var items = document.getElementsByClassName('ex-row');
      for (var i = 0; i < items.length; i++) {
        var d = new Date(items[i].querySelector('.date').innerText);
        var same = d.getFullYear() === date.getFullYear() &&
                   d.getMonth() === date.getMonth() &&
                   d.getDate() === date.getDate();
        if (same) { items[i].classList.toggle('highlight'); }
        else { items[i].classList.remove('highlight'); }
      }
    }
  });
  // 初始化后自动滚到右侧（数据密集区），小月份留在左侧
  var calContainer = document.querySelector('.cal-heatmap-container');
  if (calContainer) {
    setTimeout(function() { calContainer.scrollLeft = calContainer.scrollWidth; }, 100);
  }
  <% } %>
</script>
</body>
</html>
