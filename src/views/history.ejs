<html lang="zh">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>练习记录 · 错题助手</title>
  <link rel="stylesheet" href="/theme.css">
  <style>
    body { background: var(--paper); }
    .list-view { max-width:760px; margin:0 auto; }

    /* 日期分组标题 */
    .date-group {
      margin-bottom: 28px;
      animation: fadeSlide 0.5s var(--ease-out) both;
    }
    .date-group:nth-child(1) { animation-delay: 0s; }
    .date-group:nth-child(2) { animation-delay: 0.05s; }
    .date-group:nth-child(3) { animation-delay: 0.1s; }
    .date-group:nth-child(4) { animation-delay: 0.15s; }
    .date-group:nth-child(5) { animation-delay: 0.2s; }

    .date-header {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 14px;
      padding-bottom: 10px;
      border-bottom: 2px solid var(--g-100);
    }
    .date-header .date-text {
      font-size: 16px;
      font-weight: 700;
      color: var(--g-700);
      font-family: var(--font-display);
    }
    .date-header .date-count {
      font-size: 12px;
      color: var(--ink-400);
      background: var(--g-50);
      padding: 3px 12px;
      border-radius: 12px;
      font-weight: 500;
    }
    .date-header .deco-line {
      flex: 1;
      height: 1px;
      background: linear-gradient(90deg, var(--g-200), transparent);
    }
    .export-day-btn {
      font-size: 12px;
      font-weight: 600;
      padding: 5px 14px;
      border-radius: 8px;
      border: 0.5px solid var(--g-300);
      background: var(--g-50);
      color: var(--g-700);
      cursor: pointer;
      white-space: nowrap;
      flex-shrink: 0;
      transition: all 0.2s var(--ease-out);
      font-family: inherit;
    }
    .export-day-btn:hover {
      background: var(--g-200);
      border-color: var(--g-400);
      color: var(--g-800);
    }
    .export-day-btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }
    .export-day-btn.has-selection {
      background: var(--g-700);
      color: #fff;
      border-color: var(--g-700);
    }
    .export-day-btn.has-selection:hover {
      background: var(--g-800);
      color: #fff;
    }
    .redo-day-btn {
      font-size: 12px;
      font-weight: 600;
      padding: 5px 14px;
      border-radius: 8px;
      border: 0.5px solid var(--brand-300, #99c2ff);
      background: var(--brand-50, #e6f0ff);
      color: var(--brand-600, #0066cc);
      cursor: pointer;
      white-space: nowrap;
      flex-shrink: 0;
      transition: all 0.2s var(--ease-out);
      font-family: inherit;
    }
    .redo-day-btn:hover {
      background: var(--brand-100, #b8d4ff);
      border-color: var(--brand-400, #66a3ff);
    }
    .redo-day-btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }
    .redo-day-btn.has-selection {
      background: var(--brand-600, #0066cc);
      color: #fff;
      border-color: var(--brand-600, #0066cc);
    }
    .redo-day-btn.has-selection:hover {
      background: var(--brand-700, #0052a3);
      color: #fff;
    }
    .sel-count {
      font-size: 11px;
      color: var(--g-700);
      font-weight: 600;
      margin-left: 6px;
      padding: 1px 7px;
      background: var(--g-100);
      border-radius: 8px;
    }
    .ex-cb {
      flex-shrink: 0;
      width: 16px;
      height: 16px;
      cursor: pointer;
      accent-color: var(--g-700);
    }

    /* 列表行 */
    .ex-row {
      display: flex;
      align-items: center;
      padding: 16px 20px;
      background: var(--card);
      border: 0.5px solid var(--border-light);
      border-radius: var(--radius);
      margin-bottom: 8px;
      cursor: pointer;
      transition: all 0.35s var(--ease-out);
      gap: 16px;
      position: relative;
      overflow: hidden;
    }
    .ex-row::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 3px;
      background: linear-gradient(180deg, var(--g-300), var(--g-500));
      transform: scaleY(0);
      transform-origin: top;
      transition: transform 0.3s var(--ease-out);
    }
    .ex-row:hover::before { transform: scaleY(1); }
    .ex-row:hover {
      box-shadow: var(--shadow-sm);
      border-color: var(--g-200);
      transform: translateX(4px);
    }

    .ex-row .rate {
      font-size: 20px;
      font-weight: 800;
      font-family: var(--font-display);
      color: var(--g-600);
      flex-shrink: 0;
      min-width: 52px;
      text-align: center;
      letter-spacing: -0.5px;
    }
    .ex-row .rate.high { color: var(--success); }
    .ex-row .rate.mid { color: var(--warning); }
    .ex-row .rate.low { color: var(--danger); }

    .ex-row .main { flex:1; min-width:0; }
    .ex-row .title {
      font-size: 14px;
      font-weight: 600;
      color: var(--text);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .ex-row:hover .title { color: var(--g-700); }
    .ex-row .meta {
      display: flex;
      gap: 6px;
      margin-top: 4px;
      flex-wrap: wrap;
    }
    .ex-row .meta span {
      font-size: 11px;
      color: var(--g-600);
      background: var(--g-50);
      padding: 2px 10px;
      border-radius: 10px;
      font-weight: 500;
      border: 0.5px solid var(--g-100);
    }
    .ex-row .time {
      font-size: 12px;
      color: var(--text-ter);
      white-space: nowrap;
      flex-shrink: 0;
    }

    @keyframes fadeSlide {
      from { opacity: 0; transform: translateY(10px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── 入场动画增强 ── */
    .page-header, .ex-row, .chart-box {
      animation: fadeSlide 0.5s var(--ease-out) both;
    }
    .page-header { animation: fadeDown 0.5s var(--ease-out) both; }
    .ex-row:nth-child(1) { animation-delay: 0.1s; }
    .ex-row:nth-child(2) { animation-delay: 0.15s; }
    .ex-row:nth-child(3) { animation-delay: 0.2s; }
    .ex-row:nth-child(4) { animation-delay: 0.25s; }
    .ex-row:nth-child(n+5) { animation-delay: 0.3s; }
    @keyframes fadeDown {
      from { opacity: 0; transform: translateY(-10px); }
      to   { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>
<body>
<div class="navbar">
  <a href="/history-category-complex" class="logo"><img src="/logo.svg" alt="">错题助手</a>
  <a href="/history-category-complex">练习记录</a>
  <a href="/history" class="active">列表视图</a>
  <a href="/wrong-questions">错题本</a>
  <a href="/word-frequency">词语统计</a>
  <a href="/quiz">本地题库</a>
  <a href="/shenlun-format">公文格式</a>
  <% if (typeof userPhone !== 'undefined' && userPhone) { %><span class="nav-user"><span class="user-phone"><%= userPhone %></span><% if (typeof isAdmin !== 'undefined' && isAdmin) { %><span class="admin-badge">管理员<span class="admin-tooltip"><span class="tip-title">👑 管理员权限</span><span class="tip-item">卸载题库</span><span class="tip-item">恢复题库</span><span class="tip-item">查看回收站</span></span></span><% } %></span><% } else { %><span style="margin-left:auto;"></span><% } %>
  <a href="/setup">切换账号</a>
</div>

<div class="container list-view">
  <% if (total == 0) { %>
    <div class="page-hero">
      <div class="hero-title">列表视图</div>
      <div class="hero-sub">按日期浏览全部练习</div>
    </div>
    <div style="text-align:center;padding:80px 20px;color:var(--text-ter);">
      <div style="font-size:48px;margin-bottom:16px;">📋</div>
      <div style="font-size:16px;font-weight:600;color:var(--text-sec);margin-bottom:6px;">暂无练习记录</div>
      <div style="font-size:13px;line-height:1.8;">当前账号还没有任何练习记录<br>完成粉笔 App 上的练习后再来查看</div>
    </div>
  <% } else { %>

  <div class="page-hero">
    <div class="hero-title">列表视图</div>
    <div class="hero-sub">按日期浏览全部练习</div>
  </div>

  <% for (let dateKey of dateKeys) {
    let items = grouped[dateKey];
    let today = moment().format('YYYY-MM-DD');
    let yesterday = moment().subtract(1, 'day').format('YYYY-MM-DD');
    let displayDate;
    if (dateKey === today) displayDate = '今天';
    else if (dateKey === yesterday) displayDate = '昨天';
    else displayDate = dateKey;
  %>
    <div class="date-group">
      <div class="date-header">
        <span class="date-text"><%= displayDate %></span>
        <span class="date-count"><%= items.length %> 次练习</span>
        <span class="deco-line"></span>
        <button class="export-day-btn" onclick="exportDailyWrong(this, '<%= dateKey %>')" title="不勾选时导出当日全部错题；勾选后仅导出所选练习的错题">导出当日错题</button>
        <button class="redo-day-btn" onclick="redoDailyWrong(this, '<%= dateKey %>')" title="不勾选时重做当日全部错题；勾选后仅重做所选练习的错题">重做当日错题</button>
      </div>

      <% for (let h of items) {
        var rateClass = h.correctRate >= 80 ? 'high' : h.correctRate >= 50 ? 'mid' : 'low';
        var isLocalQuiz = !!h._isLocalQuiz;
        // 本地题库：标题显示「一级题库名 + 题目数量」
        var localTitle = isLocalQuiz
          ? ((h.source || '本地题库') + ' · ' + (h.sheet.questionCount || h.questionCount || 0) + '题')
          : cleanTitle(h.sheet.name);
      %>
        <div class="ex-row" onclick="showReport('<%= h.id %>', <%= isLocalQuiz %>)">
          <input type="checkbox" class="ex-cb" data-date="<%= dateKey %>" data-id="<%= h.id %>" onclick="event.stopPropagation()" onchange="onExerciseSelect(this, '<%= dateKey %>')">
          <span class="rate <%= rateClass %>"><%= h.correctRate %>%</span>
          <div class="main">
            <div class="title">
              <%= localTitle %>
              <% if (isLocalQuiz) { %> <span style="font-size:11px;color:#0066cc;background:#e6f0ff;padding:1px 7px;border-radius:8px;border:1px solid #b8d4ff;margin-left:6px;font-weight:600;">本地题库</span><% } %>
            </div>
            <div class="meta">
              <span><%= h.answerCount %> 题</span>
              <span><%= Math.round(moment.duration(h.elapsedTime,'seconds').asMinutes().toFixed(1)) %> 分钟</span>
              <span><%= isLocalQuiz ? '本地题库' : (h.client==='WEB'||h.client==='APP_WEB'?'电脑端':'手机端') %></span>
            </div>
          </div>
          <span class="time"><%= moment(h.updatedTime).format('HH:mm') %></span>
        </div>
      <% } %>
    </div>
  <% } %>

  <% } %>
  <div class="list-fade">- 已展示全部练习记录 -</div>
</div>

<script>
// ── Scroll entrance animations ──
(function(){
  var els = document.querySelectorAll('.anim-in');
  if(!els.length) return;
  var io = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if(e.isIntersecting){ e.target.classList.add('visible'); io.unobserve(e.target); }
    });
  }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
  els.forEach(function(el){ io.observe(el); });
})();

  function showReport(id, isLocalQuiz) {
    if (isLocalQuiz) {
      window.location = '/quiz-result/' + id + '?from=/history';
    } else {
      window.location = '/exercise/'+id+'?from=/history';
    }
  }

  // 复选框选择：更新对应日期的导出/重做按钮状态（显示选中数量）
  function onExerciseSelect(cb, date) {
    var checked = document.querySelectorAll('.ex-cb[data-date="' + date + '"]:checked');
    var cnt = checked.length;
    var exportBtn = document.querySelector('.export-day-btn[onclick*="\'' + date + '\'"]');
    var redoBtn = document.querySelector('.redo-day-btn[onclick*="\'' + date + '\'"]');
    if (exportBtn) {
      if (cnt > 0) {
        exportBtn.classList.add('has-selection');
        exportBtn.innerHTML = '导出所选错题<span class="sel-count">' + cnt + '</span>';
      } else {
        exportBtn.classList.remove('has-selection');
        exportBtn.innerText = '导出当日错题';
      }
    }
    if (redoBtn) {
      if (cnt > 0) {
        redoBtn.classList.add('has-selection');
        redoBtn.innerHTML = '重做所选错题<span class="sel-count">' + cnt + '</span>';
      } else {
        redoBtn.classList.remove('has-selection');
        redoBtn.innerText = '重做当日错题';
      }
    }
  }

  // 按日期重做当日错题（支持不选时重做全部，勾选后仅重做所选练习的错题）
  function redoDailyWrong(btn, date) {
    if (!date) return;
    var checked = document.querySelectorAll('.ex-cb[data-date="' + date + '"]:checked');
    var exerciseIds = Array.prototype.map.call(checked, function(c) {
      return c.getAttribute('data-id');
    });
    var msg = exerciseIds.length > 0
      ? '将重做 ' + date + ' 选中的 ' + exerciseIds.length + ' 个练习的错题，确认开始？'
      : '将重做 ' + date + ' 当天的全部错题，确认开始？';
    if (!confirm(msg)) return;
    var originHTML = btn.innerHTML;
    btn.disabled = true;
    btn.innerText = '加载中...';
    fetch('/api/quiz/redo', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ date: date, exerciseIds: exerciseIds })
    })
    .then(function(r) {
      if (!r.ok) return r.json().then(function(d) { throw new Error(d.error || '构建失败'); });
      return r.json();
    })
    .then(function(data) {
      if (data.setId) {
        window.location.href = '/quiz/' + data.setId + '?from=/history';
      } else {
        throw new Error('未返回题集 ID');
      }
    })
    .catch(function(e) {
      alert('重做失败：' + e.message);
      btn.disabled = false;
      btn.innerHTML = originHTML;
    });
  }

  // 按日期导出当日错题 PDF（支持不选时导出全部，勾选后仅导出所选练习的错题）
  function exportDailyWrong(btn, date) {
    if (!date) return;
    var checked = document.querySelectorAll('.ex-cb[data-date="' + date + '"]:checked');
    var exerciseIds = Array.prototype.map.call(checked, function(c) {
      return c.getAttribute('data-id');
    });
    var msg = exerciseIds.length > 0
      ? '将导出 ' + date + ' 选中的 ' + exerciseIds.length + ' 个练习的错题，确认开始？'
      : '将导出 ' + date + ' 当天的全部错题与错误词语统计，确认开始？';
    if (!confirm(msg)) return;
    var originHTML = btn.innerHTML;
    btn.disabled = true;
    btn.innerText = '生成中...';
    fetch('/api/export-daily-wrong-pdf', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ date: date, exerciseIds: exerciseIds })
    })
    .then(function(r) {
      if (!r.ok) return r.json().then(function(d) { throw new Error(d.error || '导出失败'); });
      return r.blob();
    })
    .then(function(blob) {
      var url = URL.createObjectURL(blob);
      var a = document.createElement('a');
      a.href = url;
      a.download = date + (exerciseIds.length > 0 ? '-错题(所选' + exerciseIds.length + '个练习)' : '-当日错题') + '.pdf';
      document.body.appendChild(a);
      a.click();
      a.remove();
      URL.revokeObjectURL(url);
    })
    .catch(function(e) {
      alert('导出失败：' + e.message);
    })
    .finally(function() {
      btn.disabled = false;
      btn.innerHTML = originHTML;
    });
  }
</script>
</body>
</html>
